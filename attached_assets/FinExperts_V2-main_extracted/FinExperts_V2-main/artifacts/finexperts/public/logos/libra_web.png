            $('.carousel#cardNav').on('slid.bs.carousel', function(e) {
                switch (e.to) {
                    case 0:
                        $("#ComandaCard").attr("href", "/client-card-online").attr("title", "Comanda card debit Avanpost Gold Black");

                        break;
                    case 1:
                        $("#ComandaCard").attr("href", "/client-card-online").attr("title", "Comanda card debit Avanpost Gold Roz");

                        break;
                    case 2:
                        $("#ComandaCard").attr("href", "/client-card-online").attr("title", "Comanda card debit Avanpost Gold Camuflaj");

                        break;
                    case 3:
                        $("#ComandaCard").attr("href", "https://www.libraonline.ro/pf/productDetails/ACCOUNT").attr("title", "Comanda card debit Avanpost Gold Junior");

                        break;
                }
            })

            $('.carousel#cardNav2').on('slid.bs.carousel', function(e) {
                switch (e.to) {
                    case 0:
                        $("#ComandaCard2").attr("href", "https://libraonline.ro/pf/productDetails/ONLINE_STANDARD_DEBIT_CARD").attr("title", "Comanda card debit Avanpost Free");

                        break;
                    case 1:
                        $("#ComandaCard2").attr("href", "https://www.libraonline.ro/pf/productDetails/ACCOUNT").attr("title", "Comanda card debit Avanpost Free Junior");

                        break;
                }
            })
        });
    </script>
