        <script src="https://cdn.jsdelivr.net/npm/@meilisearch/instant-meilisearch@0.13.6/dist/instant-meilisearch.umd.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/instantsearch.js@4"></script>
        <script>
            const search = instantsearch({
                indexName: "test",
                searchClient: instantMeiliSearch("https://search.librabank.ro/", "e959d81486557d8d92b74247cc39b98afe34dc0b2a8d5aa456e77cfbbd10efee"),
                finitePagination: true,
                searchFunction(helper) {
                    const container = document.querySelector("#hits");
                    const pagination = document.querySelector("#pagination");
                    const stats = document.querySelector("#stats");
                    container.style.display = helper.state.query === "" ? "none" : "";
                    pagination.style.display = helper.state.query === "" ? "none" : "";
                    stats.style.display = helper.state.query === "" ? "none" : "";

                    const containerm = document.querySelector("#hitsm");
                    const paginationm = document.querySelector("#paginationm");
                    const statsm = document.querySelector("#statsm");
                    containerm.style.display = helper.state.query === "" ? "none" : "";
                    paginationm.style.display = helper.state.query === "" ? "none" : "";
                    statsm.style.display = helper.state.query === "" ? "none" : "";

                    helper.search();
                },
            });

            search.addWidgets([
                instantsearch.widgets.searchBox({
                    container: "#searchbox",
                }),
                instantsearch.widgets.configure({
                    hitsPerPage: 5,
                    matchingStrategy: "all",
                    snippetEllipsisText: "...",
                    attributesToSnippet: ["content:20"],
                    finitePagination: false,
                }),
                instantsearch.widgets.hits({
                    container: "#hits",
                    templates: {
                        item: `
            <div>
            <div class="hit-name">
                  <a href="https://www.librabank.ro{{link}}">{{#helpers.highlight}}{ "attribute": "title" }{{/helpers.highlight}}</a><br>
                 <br><a class="snippet" href="https://www.librabank.ro{{link}}"><span class="text-wrap">{{#helpers.snippet}}{ "attribute": "content" }{{/helpers.snippet}}</span></a>
            </div>
            </div>
          `,
                        empty: "<div>Nu au fost gasite rezultate pentru {{ query }}.</div>",
                    },
                }),
                instantsearch.widgets.pagination({
                    container: "#pagination",
                }),
                instantsearch.widgets.stats({
                    container: "#stats",
                    templates: {
                        text(hit) {
                            return `<strong>${
          hit.nbHits
        }</strong> rezultate ${
          hit.query !== "" ? `pentru <strong>"${hit.query}"</strong>` : ``
        } in <strong>${hit.processingTimeMS} ms</strong><br><a href="javascript:void()"  onclick="redirectSearch()">Afiseaza toate rezultatele</a>`;
                        }
                    }
                })
            ]);

            search.addWidgets([
                instantsearch.widgets.searchBox({
                    container: "#searchboxm",
                }),
                instantsearch.widgets.configure({
                    hitsPerPage: 5,
                    matchingStrategy: "all",
                    snippetEllipsisText: "...",
                    attributesToSnippet: ["content:20"],
                    finitePagination: false,
                }),
                instantsearch.widgets.hits({
                    container: "#hitsm",
                    templates: {
                        item: `
            <div>
            <div class="hit-name">
                  <a href="https://www.librabank.ro{{link}}">{{#helpers.highlight}}{ "attribute": "title" }{{/helpers.highlight}}</a><br>
                 <br><a class="snippet" href="https://www.librabank.ro{{link}}"><span class="text-wrap">{{#helpers.snippet}}{ "attribute": "content" }{{/helpers.snippet}}</span></a>
            </div>
            </div>
          `,
                        empty: "<div>Nu au fost gasite rezultate pentru {{ query }}.</div>",
                    },
                }),
                instantsearch.widgets.pagination({
                    container: "#paginationm",
                }),
                instantsearch.widgets.stats({
                    container: "#statsm",
                    templates: {
                        text(hit) {
                            return `<center><strong>${
                    hit.nbHits
                    }</strong> rezultate ${
                    hit.query !== "" ? `pentru <strong>"${hit.query}"</strong>` : ``
                    } in <strong>${hit.processingTimeMS} ms</strong><br><a class="morerez" href="javascript:void()" onclick="redirectSearch()">Afiseaza toate rezultatele</a></center>`;
                        }
                    }
                })
            ]);

            search.start();

            let timer;

            const waitTime = 1000;

            const messageInput = document.getElementById("searchbox");

            messageInput.addEventListener("keyup", (event) => {
                clearTimeout(timer);

                timer = setTimeout(() => {
                    doneTyping(event.target.value);
                }, waitTime);
            });

            const messageInputm = document.getElementById("searchboxm");

            messageInputm.addEventListener("keyup", (event) => {
                clearTimeout(timer);

                timer = setTimeout(() => {
                    doneTyping(event.target.value);
                }, waitTime);
            });

            function doneTyping(value) {
                if (value != "") {
                    postAjax("/logsearch.php", "search=" + value, function(data) {
                        console.log(data);
                    });
                    console.log(`The user is done typing: ${value}`);
                }
            }

            function postAjax(url, data, success) {
                var params =
                    typeof data == "string" ?
                    data :
                    Object.keys(data)
                    .map(function(k) {
                        return encodeURIComponent(k) + "=" + encodeURIComponent(data[k]);
                    })
                    .join("&");

                var xhr = window.XMLHttpRequest ? new XMLHttpRequest() : new ActiveXObject("Microsoft.XMLHTTP");
                xhr.open("POST", url);
                xhr.onreadystatechange = function() {
                    if (xhr.readyState > 3 && xhr.status == 200) {
                        success(xhr.responseText);
                    }
                };
                xhr.setRequestHeader("X-Requested-With", "XMLHttpRequest");
                xhr.setRequestHeader("Content-Type", "application/x-www-form-urlencoded");
                xhr.send(params);
                return xhr;
            }


            function redirectSearch() {

                var form = document.createElement("form");
                $(form).attr("id", "reg-form").attr("name", "reg-form").attr("action", "/Cautare").attr("method", "post").attr("enctype", "multipart/form-data");

                const input = document.createElement('input')
                input.name = "searchText"

                val1 = document.getElementsByClassName("ais-SearchBox-input")[0].value
                if (val1 == "") val = document.getElementsByClassName("ais-SearchBox-input")[1].value


                input.value = val1;
                form.appendChild(input)

                document.body.appendChild(form);
                form.submit();
                document.body.removeChild(form);

                return false;
            }

            $(".ais-SearchBox-input").each(function() {
                $(this).attr('placeholder', 'Cauta...');
            });
            
            $(".ais-SearchBox-submit").on("click", function() {
                redirectSearch()
            });

            //back to top
            $(function() {
                $('#goToTop').click(function() {
                    window.scrollTo({
                        top: 0,
                        behavior: 'smooth'
                    });
                });
            });


            //IBAN fintech
            jQuery(document).ready(function() {
                jQuery('#IBANfintech').on('click', function(e) {
                    e.preventDefault();
                    const fintech = ["00055", "00056", "00059", "00060", "00061", "00062", "00063", "00068", "00069", "00070", "00071", "00072"];
                    var iban = $('#IBAN').val().split(" ").join("").toUpperCase();
                    var iban_result = $('#IBANresult');
                    if (iban.length != 24)
                        iban_result.html("IBAN-ul introdus nu este valid");
                    else if (iban.substring(4, 8).toLowerCase() != "brel")
                        iban_result.html("IBAN-ul introdus nu apartine Libra sau unui partener din categoria fintech");
                    else if (!fintech.includes(iban.substring(8, 13)))
                        iban_result.html("IBAN-ul introdus nu apartine unui partener din categoria fintech");
                    else {
                        iban_result.html("...se verifica...");
                        $.ajax({
                                method: "POST",
                                url: '/ajax/fintech.php',
                                data: {
                                    Iban: iban
                                }
                            })
                            .done(function(result) {
                                result = JSON.parse(result);

                                if (result.result == 1) {
                                    if (result.data)
                                        iban_result.html("IBAN-ul introdus este gestionat de " + result.data);
                                    else
                                        iban_result.html("IBAN-ul introdus nu este alocat in prezent");
                                } else {
                                    iban_result.html("Eroare validare - va rugam incercati mai tarziu...");
                                }
                            });
                    }

                    return false;

                })
            })
        </script>
        


