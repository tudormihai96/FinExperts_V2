    <script>
        var isWindowHidden = false;

        $(window).on('blur', function() {
            isWindowHidden = true;
        });

        function callOpenApp(type, elem) {
            var IS_IPAD = navigator.userAgent.match(/iPad/i) != null,
                IS_IPHONE = !IS_IPAD && ((navigator.userAgent.match(/iPhone/i) != null) || (navigator.userAgent.match(/iPod/i) != null)),
                IS_IOS = IS_IPAD || IS_IPHONE,
                IS_ANDROID = !IS_IOS && navigator.userAgent.match(/android/i) != null,
                IS_HUAWEI = !IS_IOS && navigator.userAgent.match(/huawei/i) != null,
                IS_MOBILE = IS_IOS || IS_ANDROID;

            isWindowHidden = false;

            var mbkBaseUrl = "librabank://dispatcherForPN?";
            var ibkBaseUrl = "https://secure.internetbanking.ro/IBK_SMS/";
            var iosStore = "https://itunes.apple.com/app/id691914413?l=ro";
            var androidStore = "https://play.google.com/store/apps/details?id=libra.mobile.banking";

            var appAndroidPackage = "libra.mobile.banking";

            var mbkUrl = '';
            var ibkUrl = '';

            switch (type) {
                case "card":
                    mbkUrl = mbkBaseUrl + "action=menulink&id=27";
                    ibkUrl = ibkBaseUrl + "Carduri/EmitereCarduri.aspx";
                    break;
                case "depozit":
                    mbkUrl = mbkBaseUrl + "action=menulink&id=9";
                    ibkUrl = ibkBaseUrl + "Login/LoginFirstStep.aspx?ReturnUrl=%2fIBK_SMS%2fDepozite%2fConstituireDepozit.aspx";
                    break;
                case "cardCredit":
                    mbkUrl = mbkBaseUrl + "action=menulink&id=28";
                    ibkUrl = ibkBaseUrl + "Carduri/CreditCardStep1.aspx?status=new ";
                    break;
                case "creditOnline":
                    mbkUrl = mbkBaseUrl + "action=menulink&id=10";
                    ibkUrl = ibkBaseUrl + "Login/LoginFirstStep.aspx?ReturnUrl=%2fIBK_SMS%2fCredite%2fSumarCredite.aspx";
                    break;
                case "economii":
                    mbkUrl = mbkBaseUrl + "action=menulink&id=46";
                    ibkUrl = ibkBaseUrl + "Login/LoginFirstStep.aspx?ReturnUrl=%2fIBK_SMS%2fDepozite%2fConturiEconomiiActive.aspx";
                    break;
            }

            function openApp(elem) {
                setTimeout(function() {
                    $(elem).closest(".btn").after(`
            <div id="infoOpenApp" class="" style="font-size: 13px; text-align: center;">
                Daca nu ai fost deja redirectionat catre aplicatia de mobile banking, poti <a href="` + ibkUrl + `" style="text-decoration: underline;">continua aici in browser</a>
            </div>
            `);
                }, 5000);

                if (IS_IOS) {
                    window.location = mbkUrl;
                    setTimeout(function() {
                        if (isWindowHidden == false) {
                            window.location = iosStore;
                        }
                    }, 3000);
                } else {
                    if (IS_HUAWEI) {
                        setTimeout(function() {
                            if (isWindowHidden == false) {
                                window.location = "appmarket://details?id=libra.mobile.banking"
                            }
                        }, 2000);
                    }
                    window.location = "intent:/" + mbkUrl.split(":/")[1] + "#Intent;package=" + appAndroidPackage + ";scheme=" + mbkUrl.split(":/")[0] + ";launchFlags=268435456;end;";
                }
            }

            if (IS_MOBILE) {
                openApp(elem);
            } else {
                window.location = ibkUrl;
            }
        }
        function mbkwidget(app = "ibk") {
            var isWindowHidden = false;

            $(window).on('blur', function() {
                isWindowHidden = true;
            });

            var IS_IPAD = navigator.userAgent.match(/iPad/i) != null,
                IS_IPHONE = !IS_IPAD && ((navigator.userAgent.match(/iPhone/i) != null) || (navigator.userAgent.match(/iPod/i) != null)),
                IS_IOS = IS_IPAD || IS_IPHONE,
                IS_ANDROID = !IS_IOS && navigator.userAgent.match(/android/i) != null,
                IS_HUAWEI = !IS_IOS && navigator.userAgent.match(/huawei/i) != null,
                IS_MOBILE = IS_IOS || IS_ANDROID;

            isWindowHidden = false;
            if (app == 'ibk') {
                var mbkBaseUrl = "librabank://dispatcherForPN?";
                var ibkBaseUrl = "https://secure.internetbanking.ro/IBK_SMS/";

                var iosStore = "https://itunes.apple.com/app/id691914413?l=ro";
                var androidStore = "https://play.google.com/store/apps/details?id=libra.mobile.banking";

                var appAndroidPackage = "libra.mobile.banking";
            }
            if (app == 'lj') {
                var mbkBaseUrl = "librawallet://dispatcherForPN?";
                var ibkBaseUrl = "https://wallet.librapay.ro/";

                var iosStore = "https://itunes.apple.com/app/id578226289?l=ro";
                var androidStore = "https://play.google.com/store/apps/details?id=libra.bank";

                var appAndroidPackage = "libra.bank";
            }
            if (app == 'mbk') {
                var mbkBaseUrl = "librabank://dispatcherForPN?action=menulink";
                var ibkBaseUrl = "/link-aplicatii-online";

                var iosStore = "https://itunes.apple.com/app/id691914413?l=ro";
                var androidStore = "https://play.google.com/store/apps/details?id=libra.mobile.banking";

                var appAndroidPackage = "libra.mobile.banking";
            }

            if (app == 'mpos') {
                var mbkBaseUrl = "https://play.google.com/store/apps/details?id=com.provisionpay.softpos.libra";
                var ibkBaseUrl = "/link-aplicatii-mpos";
                var androidStore = "https://play.google.com/store/apps/details?id=com.provisionpay.softpos.libra";

                var appAndroidPackage = "com.provisionpay.softpos.libra";
            }

            if (IS_MOBILE) {
                if (IS_IOS) {

                    window.location = iosStore;

                } else {
                    if (IS_HUAWEI && app == 'mbk') {
                        setTimeout(function() {
                            if (isWindowHidden == false) {
                                window.location = "appmarket://details?id=libra.mobile.banking"
                            }
                        }, 2000);
                    }

                    window.location = "intent:/" + mbkBaseUrl.split(":/")[1] + "#Intent;package=" + appAndroidPackage + ";scheme=" + mbkBaseUrl.split(":/")[0] + ";launchFlags=268435456;end;";
                }

            } else {
                window.location = ibkBaseUrl;
            }
        }
    </script>




    <script>
        var referrer = document.referrer;

        function showOverlayer(ip) {
            var overlayerCookie = isNaN($.cookie('overlayer' + ip)) ? 0 : $.cookie('overlayer' + ip);
            var date = new Date();
            var overlayer_ip = 'overlayer' + ip;

            date.setTime(date.getTime() + 86400000 * 155);
            $.cookie(overlayer_ip, "teste", {
                expires: date
            });

            if (overlayerCookie < 3) {
                $.cookie('overlayer' + ip, parseInt(overlayerCookie) + 1, {
                    expires: date
                });
                return true;
            }
            return false;
        }
    </script>


    <script type="text/javascript">
        function showMenu() {
            var x = document.getElementById("dropmenu");
            $('#dropmenu').toggle('fast');
            $('#searchbox').hide('fast');
        }

        function showSearch() {
            var x = document.getElementById("searchbox");
            $('#searchbox').toggle('fast');
            $('#dropmenu').hide('fast');
        }

        $(document).on('click', function(event) {
            var $target = $(event.target);
            if (!$target.closest('#header').length &&
                $('#dropmenu').is(":visible")) {
                $('#dropmenu').hide();
            }
        });
    </script>


