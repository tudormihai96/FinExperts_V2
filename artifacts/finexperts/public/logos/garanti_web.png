					<style>
  .searchInputWrapper {
    display: flex;
    gap: 1px;
    border-bottom: 1px solid #225a8f;
    padding-bottom: 13px;
    margin-bottom: 28px;
  }

  .icon-search {
    padding-right: 16px;
    height: 24px;
    width: 40px;
  }

  #search-input-popup {
    border: none;
    color: #121212;
    font-size: 19px;
    font-family: "BentonSansBBVA-Book", Sans-serif;
    padding: 0px 0px 0px 1px;
    height: 24px;
  }

  #search-input-popup ::placeholder {
    color: #b8b8b8;
    font-size: 19px;
    font-family: "BentonSansBBVA-Book", Sans-serif;
  }

  #search-input-popup :focus {
    outline: none;
  }

  .searchResult {
    text-decoration: none;
    color: #225a8f;
    font-family: "BentonSansBBVA-Book", Sans-serif;
    font-size: 15px;
  }

  #search-results-popup,
  .search-results-frequent-popup {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 0;
    margin: 0;
  }

  .searchResult.seeMore {
    color: #1464a5;
    font-family: "BentonSansBBVA-Medium", Sans-serif;
    font-size: 15px;
    text-decoration: none;
  }

  #search-results-popup > li:last-child {
    margin-top: 1rem;
  }

  .frequentSearchesPopup > h2 {
    color: #121212;
    font-family: "BentonSansBBVA-Book", Sans-serif;
    font-size: 19px;
    font-weight: 100;
    line-height: 24px;
    margin: 0;
    margin-bottom: 2rem;
  }

  li {
    list-style-type: none;
  }
</style>
<div class="searchInputWrapper">
  <div class="icon-search">
    <svg xmlns="http://www.w3.org/2000/svg" id="Desktop" width="24" height="24" viewBox="0 0 24 24">
      <g id="_1200_scroll" data-name="1200_scroll">
        <path id="icon-search" d="M1194.815,28a9.82,9.82,0,0,1,9.827,9.818,9.712,9.712,0,0,1-1.882,5.766l6.24,6.234L1206.815,52l-6.228-6.234A9.819,9.819,0,1,1,1194.815,28Zm0,1.939a7.879,7.879,0,1,1-7.87,7.879A7.877,7.877,0,0,1,1194.815,29.939Zm0,1.333v2.182a4.368,4.368,0,0,1,4.37,4.364h2.173A6.545,6.545,0,0,0,1194.815,31.273Z" transform="translate(-1185 -28)" fill="#004481" fill-rule="evenodd" />
      </g>
    </svg>
  </div>
  <input type="text" id="search-input-popup" placeholder="Search" />
</div>
<div id="resultsContainer">
  <div class="frequentSearchesPopup">
    <h2>Căutări frecvente</h2>
    <ul class="search-results-frequent-popup">
      <li>
        <a class="searchResult" href="/persoane-fizice/conturi-curente-si-carduri-de-debit/cont-curent-in-lei">Cont curent în lei</a>
      </li>
      <li>
        <a class="searchResult" href="/persoane-fizice/credite/credit-de-nevoi-personale/">Credit de nevoi personale</a>
      </li>
      <li>
        <a class="searchResult" href="/persoane-fizice/bonus-card/">Bonus card</a>
      </li>
      <li>
        <a class="searchResult" href="/persoane-fizice/online-banking/">Garanti BBVA Online</a>
      </li>
    </ul>
  </div>
  <ul id="search-results-popup"></ul>
</div>

<script>
  var postTypesPopup = ["exportedaparitii", "exportedcomunicate", "exportedpages", "exportedposts"];
  var allData = [];
  var queryPopup = "";
  function loadAllDataPopup() {
    for (var i = 0; i < postTypesPopup.length; i++) {
      var fileUrl = "/wp-content/themes/hello-theme-child-master/" + postTypesPopup[i] + ".json";
      var xhr = new XMLHttpRequest();
      xhr.open("GET", fileUrl, false);
      xhr.send(null);
      if (xhr.status === 200) {
        var data = JSON.parse(xhr.responseText);
        for (var j = 0; j < data.length; j++) {
          if (data[j].language === "ro") {
            allData.push(data[j]);
          }
        }
      }
    }
  }

  function searchPostsPopup(queryPopup, event) {
    if (event.keyCode === 13) {
  fetch("https://trackingleads-e0192.web.app/api/searchQueriesSubmissions", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
    },
    body: JSON.stringify({ searchQuery: queryPopup }),
  })
  .then((response) => {
    if (response.ok) {
      // Redirect immediately if response is ok, skip parsing JSON
      window.location.href = "/rezultatele-cautarii";
    } else {
      throw new Error("Network response was not ok.");
    }
  })
  .catch((error) => console.error("Error submitting query:", error));
}


    // Define a mapping of diacritic characters to their ASCII counterparts
    const diacriticMap = {
      ă: "a",
      â: "a",
      î: "i",
      ș: "s",
      ț: "t",
    };

    queryPopup = queryPopup.replace(/[ăâîșț]/g, (match) => diacriticMap[match]);

    var searchContent = "";
    for (var i = 0; i < allData.length; i++) {
      var urlParts = allData[i].url.split("/");
      var lastUrlPart = urlParts[urlParts.length - 1];
      var urlText = lastUrlPart.replace(/-/g, " ");

      searchContent += allData[i].title + " " + allData[i].content + " " + urlText + " ";
    }

    searchContent = searchContent.replace(/[ăâîșț]/g, (match) => diacriticMap[match]);

    var queryIndex = searchContent.toLowerCase().indexOf(queryPopup.toLowerCase());
    if (queryIndex >= 0) {
      var matchingPostsPopup = [];
      for (var i = 0; i < allData.length; i++) {
        var urlParts = allData[i].url.split("/");
        var lastUrlPart = urlParts[urlParts.length - 1];
        var urlText = lastUrlPart.replace(/-/g, " ");

        var postContent = allData[i].title + " " + allData[i].content + " " + urlText + " ";

        postContent = postContent.replace(/[ăâîșț]/g, (match) => diacriticMap[match]);

        var matches = postContent.toLowerCase().match(new RegExp(queryPopup.toLowerCase(), "g"));
        if (matches) {
          matchingPostsPopup.push({ post: allData[i], matches: matches.length });
        }
      }

      if (matchingPostsPopup.length > 0) {
        document.querySelector(".frequentSearchesPopup").style.display = "none";
        matchingPostsPopup.sort(function (a, b) {
          return b.matches - a.matches;
        });
        if (queryPopup.length >= 3) {
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({
            event: "view_search_results",
            search_term: `${queryPopup}`,
          });
        }

        var resultsPopup = "";
        var limit = Math.min(matchingPostsPopup.length, 9);
        for (var i = 0; i < limit; i++) {
          var post = matchingPostsPopup[i].post;
          resultsPopup += `<li><a href="${post.url}" class="searchResult">${post.title}</a></li>`;
        }
        resultsPopup += '<li><a href="/rezultatele-cautarii?searchTerm=" class="searchResult seeMore">Vezi toate rezultatele</a></li>';

        document.getElementById("search-results-popup").innerHTML = resultsPopup;
      } else {
        document.querySelector(".frequentSearchesPopup").style.display = "none";
        document.getElementById("search-results-popup").innerHTML = "Nu sunt rezultate.";
      }
    } else {
      document.querySelector(".frequentSearchesPopup").style.display = "none";
      document.getElementById("search-results-popup").innerHTML = "Nu sunt rezultate.";
    }
  }

  loadAllDataPopup();

  document.getElementById("search-input-popup").addEventListener("keyup", function () {
    queryPopup = this.value;
    localStorage.setItem("searchQuery", queryPopup);
    searchPostsPopup(queryPopup, event);

    if (queryPopup.length >= 3) {
      searchPostsPopup(queryPopup);
      document.querySelector(".frequentSearchesPopup").style.display = "none";
    } else {
      document.getElementById("search-results-popup").innerHTML = "";
      document.querySelector(".frequentSearchesPopup").style.display = "block";
    }
  });
</script>
