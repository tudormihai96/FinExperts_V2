<script>
  //  ------------------------ ADOBE ANALYTICS ------------------------------

  const devHostname = "edicion-la83d4oj";
  const stagingHostname = "revision-la83d4oj";
  const productionHostname23 = "www.garantibbva.ro";

  // Helper Functions

  function isDevelopmentOrStaging() {
    const hostname = window.location.hostname;
    return (
      hostname.includes("edicion-la83d4oj") ||
      hostname.includes("revision-la83d4oj")
    );
  }

  function debugLog(...args) {
    if (isDevelopmentOrStaging()) {
      console.log(...args);
    }
  }

  // Determine the language based on the URL
  function getLanguage() {
    const pathSegments = window.location.pathname.split("/").filter(Boolean);
    // If the first path segment is 'en', return 'en', otherwise return 'ro'
    return pathSegments[0] === "en" ? "en" : "ro";
  }

  // Check if the clicked element is an internal link
  function isInternalLink(element) {
    debugLog("element::", element);
    debugLog("element.hostname::", element.hostname);
    // Compare the hostname of the link with the current page's hostname
    return (
      element.hostname.includes(window.location.hostname) ||
      element.hostname.includes(devHostname) ||
      element.hostname.includes(stagingHostname) ||
      element.hostname.includes(productionHostname23)
    );
  }

  // Get the last segment of the URL as the page name
  function getLastUrlParameter() {
    const pathArray = window.location.pathname.split("/").filter(Boolean);
    // Return the last non-empty segment, or 'home' if the path is empty
    return pathArray[pathArray.length - 1] || "home";
  }

  // Determine the position/section of the clicked element
  function getElementPosition(element) {
    debugLog(element);

    // Get the current page path
    const currentPath = window.location.pathname;

    // ==================== HOMEPAGE  ====================
    if (currentPath === "/" || currentPath === "/en/individuals") {
      if (element.closest(".elementor-element-c3c374c")) {
        return "carousel";
      }
      if (element.closest(".elementor-element.elementor-element-164a12c")) {
        return "call-to-action";
      }

      if (element.closest(".elementor-element.elementor-element-50c7e5b")) {
        return "fraud-alert";
      }
    }

    // ==================== INFO BONUS CARD PAGE  ====================
    if (
      currentPath === "/persoane-fizice/bonus-card/info-bonus-card" ||
      currentPath === "/en/individuals/bonus-card/info-bonus-card"
    ) {
      if (
        element.closest(".elementor-element-e24dfa1") ||
        element.closest(".elementor-element-de3262d") ||
        element.closest(".elementor-element-abef6e2")
      ) {
        return "main-info";
      }
      if (element.closest(".elementor-element-83b873c")) {
        return "breadcrumbs";
      }
      if (element.closest(".elementor-element-46180be")) {
        return "useful-links";
      }
    }
    // ====================  BONUS CARD PAGE  ====================
    if (
      currentPath === "/persoane-fizice/bonus-card" ||
      currentPath === "/en/individuals/bonus-card"
    ) {
      if (
        element.closest(".elementor-element-82132c4") ||
        element.closest(".elementor-element-7e8d8d0")
      ) {
        return "not-a-client-yet";
      }
      if (
        element.closest(".elementor-element-7bf8e4c") ||
        element.closest(".elementor-element-4f5f53d")
      ) {
        return "first-carousel";
      }
      if (
        element.closest(".elementor-element-0a49b63") ||
        element.closest(".elementor-element-d50e8df")
      ) {
        return "second-carousel";
      }
      if (
        element.closest(".elementor-element-b2d0134") ||
        element.closest(".elementor-element-48856d1")
      ) {
        return "breadcrumbs";
      }
    }

    // ==================== BONUS CARD PAGE 2  ====================
    if (
      currentPath === "/persoane-fizice/bonus-card-2" ||
      currentPath === "/en/individuals/bonus-card-2"
    ) {
      if (
        element.closest(".elementor-element-4f5f53d") ||
        element.closest(".elementor-element-7bf8e4c")
      ) {
        return "carousel";
      }
      if (element.closest(".elementor-element-2e2d001")) {
        return "partners";
      }
      if (
        element.closest(".elementor-element-916baac") ||
        element.closest(".elementor-element-5b461a3")
      ) {
        return "info-cards";
      }
      if (
        element.closest(".elementor-element-82132c4") ||
        element.closest(".elementor-element-7e8d8d0")
      ) {
        return "not-a-client-yet";
      }
      if (
        element.closest(".elementor-element-b2d0134") ||
        element.closest(".elementor-element-48856d1")
      ) {
        return "breadcrumbs";
      }
    }

    // Fallback checks for all pages
    if (element.closest("div.elementor-location-header")) {
      return "header";
    }
    if (element.closest("div.elementor-location-footer")) {
      return "footer";
    }
    if (element.closest(".elementor-element.elementor-element-76f2017")) {
      return "useful-links";
    }
    if (element.closest(".elementor-element.elementor-element-a4f5dab")) {
      return "banner";
    }

    if (element.closest("section.elementor-top-section")) {
      const section = element.closest("section.elementor-top-section");
      const trackingClass = Array.from(section.classList).find((className) =>
        className.startsWith("adobe-tracking-")
      );

      if (trackingClass) {
        // Extract everything after 'adobe-traking-' to get the section name
        return trackingClass.replace("adobe-tracking-", "");
      }
    }
    if (element.closest("section#iconsAboutUs")) {
      return "useful-links";
    }

    // Function to check if an h2 or h3 matches the specific styles
    function isMatchingHeading(heading) {
      const style = window.getComputedStyle(heading);

      // Define all possible heading styles
      const headingStyles = [
        {
          fontFamily: "BentonSansBBVA-Light",
          fontSize: "36px",
          fontWeight: "100",
          lineHeight: "48px",
        },
        {
          fontFamily: "BentonSansBBVA-Bold",
          fontSize: "40px",
          fontWeight: "700",
          lineHeight: "48px",
        },
        {
          fontFamily: "BentonSansBBVA-Bold",
          fontSize: "40px",
          fontWeight: "700",
          lineHeight: "56px",
        },
        {
          fontFamily: "BentonSansBBVA-Book",
          fontSize: "36px",
          fontWeight: "100",
          lineHeight: "48px",
        },
      ];

      // Check if the heading matches any of the defined styles
      return headingStyles.some((validStyle) => {
        return Object.entries(validStyle).every(([property, value]) => {
          return style[property].includes(value);
        });
      });
    }

    // Find the nearest preceding h2 or h3, potentially looking in previous sections
    let currentElement = element;
    while (currentElement && currentElement !== document.body) {
      // Check for h2 or h3 in the current element
      let heading = currentElement.querySelector("h2, h3");
      if (heading && isMatchingHeading(heading)) {
        return heading.textContent.trim();
      }

      // If current element is a section and no matching heading found,
      // move to the previous sibling section
      if (currentElement.tagName.toLowerCase() === "section") {
        let previousSection = currentElement.previousElementSibling;
        while (previousSection) {
          if (previousSection.tagName.toLowerCase() === "section") {
            heading = previousSection.querySelector("h2, h3");
            if (heading && isMatchingHeading(heading)) {
              return heading.textContent.trim();
            }
          }
          previousSection = previousSection.previousElementSibling;
        }
      }

      // Move up to the parent element
      currentElement = currentElement.parentElement;
    }

    // If no matching h2 or specific section is found, return a default value
    return "main";
  }

  // Main tracking function
  function trackInteraction(event) {
    // Add check for chatbot clicks
    if (event.target.closest("div.druid__minimizable__web-chat__chat-box")) {
      return; // Exit early if click is within chatbot
    }

    const clickedElement =
      event.target.tagName.toLowerCase() === "a"
        ? event.target
        : event.target.closest("a");
    debugLog("clickedElement::", clickedElement);
    if (!clickedElement) return;

    const language = getLanguage();
    const pageName = getLastUrlParameter();
    const linkPosition = getElementPosition(clickedElement);
    const isExitLink = !isInternalLink(clickedElement);

    let linkName = "";

    // ================ LOGO IMAGE CLICKS =================
    const clickedImage = clickedElement.querySelector("img");
    if (clickedImage) {
      const imageSrc = clickedImage.getAttribute("src");
      if (
        imageSrc ===
          `${window.location.origin}/wp-content/uploads/2023/01/Layer-2.png` ||
        imageSrc ===
          `${window.location.origin}/wp-content/uploads/2023/01/1200-1.svg`
      ) {
        linkName = "Garanti BBVA LOGO";
      }
    }

    // ================ BONUSCARD SLIDER CLICKS =================
    const pathToLinkName = {
      "/persoane-fizice/bonus-card/wwf-bonus-card/": "WWF Bonus Card",
      "/en/individuals/bonus-card/wwf-bonus-card/": "WWF Bonus Card",
      "/persoane-fizice/bonus-card/bonus-card-platinum/": "Bonus Card Platinum",
      "/en/individuals/bonus-card/bonus-card-platinum/": "Bonus Card Platinum",
      "/persoane-fizice/bonus-card/bonus-card-classic/": "Bonus Card Classic",
      "/en/individuals/bonus-card/bonus-card-classic/": "Bonus Card Classic",
      "/persoane-fizice/bonus-card/bonus-card-gold/": "Bonus Card Gold",
      "/en/individuals/bonus-card/bonus-card-gold/": "Bonus Card Gold",
    };

    // ================ TOP NAVBAR BANNERS =================
    const bannerPathToLinkName = {
      // Romanian paths
      "/campanii-curente/campanie-bonus-card-100-online":
        "BonusCard Banner Image",
      "/persoane-fizice/conturi-curente-si-carduri-de-debit/cont-curent-in-lei":
        "Conturi si operatiuni Banner Image",
      "/persoane-fizice/conturi-de-economii/": "Economisire Banner Image",
      "/campanii-curente/campanie-de-creditare-credit-100-online-2":
        "Credite Banner Image",
      "/persoane-fizice/mobile-banking/avantaje-si-beneficii/":
        "Canale digitale Banner Image",
      "/persoane-fizice/asigurari-atasate-creditelor/":
        "Bancassurance Banner Image",
      "/persoane-fizice/bonus-card/aplica": "Campanii Banner Image",

      // English paths
      "/en/campaigns/bonus-card-100-online-campaign": "BonusCard Banner Image",
      "/en/individuals/current-accounts-and-debit-cards/current-account-in-lei":
        "Conturi si operatiuni Banner Image",
      "/en/individuals/savings-accounts/": "Economisire Banner Image",
      "/en/campaigns/lending-campaign-100-online-credit-2":
        "Credite Banner Image",
      "/en/individuals/mobile-banking/advantages-and-benefits/":
        "Canale digitale Banner Image",
      "/en/individuals/loan-related-insurances/": "Bancassurance Banner Image",
      "/en/individuals/bonus-card/apply": "Campanii Banner Image",
    };
    // Social media URL mapping
    const imagesUrlMap = {
      "https://www.facebook.com/GarantiBBVARomania/":
        "GarantiBBVA Facebook profile",
      "https://twitter.com/GarantiBBVARo": "GarantiBBVA X Profile",
      "https://www.instagram.com/garantibbva_romania/":
        "GarantiBBVA Instagram profile",
      "https://www.linkedin.com/company/garanti-bbva-romania/":
        "GarantiBBVA LinkedIn profile",
      "https://www.youtube.com/c/GarantiBBVARomania":
        "GarantiBBVA YouTube profile",
      "https://anpc.ro/ce-este-sal/": "ANPC",
    };

    // Check if the clicked URL matches any social media URLs
    if (imagesUrlMap[clickedElement.href]) {
      linkName = imagesUrlMap[clickedElement.href];
    } else {
      // Existing logo image handling
      const logoImage = clickedElement.querySelector("img");
      if (logoImage) {
        if (
          logoImage.src.includes("/wp-content/uploads/2023/01/Layer-2.png") ||
          logoImage.src.includes("/wp-content/uploads/2023/01/1200-1.svg")
        ) {
          linkName = "Garanti BBVA LOGO";
        } else {
          linkName = logoImage.alt || "";
        }
      }
    }

    if (!linkName && clickedElement.href) {
      const path = new URL(clickedElement.href).pathname;
      if (pathToLinkName[path]) {
        linkName = pathToLinkName[path];
      } else if (
        bannerPathToLinkName[path] &&
        clickedElement.closest("div.elementor-location-header")
      ) {
        linkName = bannerPathToLinkName[path];
      }
    }

    // ================ IMAGE BOX WRAPPER CLICKS =================
    const imageBoxWrapper = clickedElement.closest(
      ".elementor-image-box-wrapper"
    );
    if (imageBoxWrapper && !linkName) {
      if (clickedElement.querySelector("img")) {
        // If the clicked element contains an image, find the text link in the title
        const textLink = imageBoxWrapper.querySelector(
          ".elementor-image-box-title a"
        );
        if (textLink) {
          linkName = textLink.textContent.trim();
        }
      } else if (clickedElement.closest(".elementor-image-box-description")) {
        // If the clicked element is in the description, use the title text
        const titleLink = imageBoxWrapper.querySelector(
          ".elementor-image-box-title a"
        );
        if (titleLink) {
          linkName = titleLink.textContent.trim();
        }
      } else {
        // If it's the title link, use its text content
        linkName = clickedElement.textContent.trim();
      }
    }

    // If linkName is still empty, use the default method
    if (!linkName) {
      linkName = clickedElement.innerHTML
        .replace(/<br\s*\/?>/gi, "\n")
        .replace(/<\/?[^>]+(>|$)/g, "")
        .split("\n")[0]
        .trim();

      // If linkName is still empty after processing, fall back to textContent
      if (!linkName) {
        linkName = clickedElement.textContent.trim().split("\n")[0].trim();
      }
    }

    const hostname = window.location.hostname;
    const linkUrl = clickedElement.href || "";

    // Create different dataLayer objects based on link type
    if (isExitLink) {
      const exitDataLayerObject = {
        event: "exitLinkClick",
        web: {
          webPageDetails: {
            name: pageName,
          },
          webInteraction: {
            name: linkName,
            linkPosition: linkPosition,
            type: "exit",
            URL: linkUrl,
          },
        },
      };

      // Push exit link data to adobeDataLayer
      if (window.adobeDataLayer) {
        window.adobeDataLayer.push(exitDataLayerObject);
        debugLog("Pushed exit link to Adobe Data Layer:", exitDataLayerObject);
      }
      debugLog("External Navigation:", exitDataLayerObject);
    } else {
      // Existing internal link tracking
      const internalDataLayerObject = {
        event: "customLinkClick",
        web: {
          webPageDetails: {
            name: pageName,
          },
          webInteraction: {
            name: linkName,
            linkPosition: linkPosition,
            type: "other",
            URL: linkUrl,
          },
        },
      };

      if (window.adobeDataLayer) {
        window.adobeDataLayer.push(internalDataLayerObject);
        debugLog("Pushed to Adobe Data Layer:", internalDataLayerObject);
      }
      debugLog("Internal Navigation:", internalDataLayerObject);
      debugLog(
        "Internal Navigation:",
        internalDataLayerObject.web.webInteraction.linkPosition
      );
    }

    if (!window.adobeDataLayer && isDevelopmentOrStaging()) {
      console.error("Adobe Data Layer not found");
    }
  }

  // Initialize tracking by adding a click event listener to the body
  function initializeTracking() {
    document.body.addEventListener("click", trackInteraction);
    debugLog("Internal navigation tracking initialized");
  }

  // Function to add breadcrumbs tracking class to last section
  function addBreadcrumbsTrackingClass() {
    const main = document.querySelector("main");
    if (main) {
      const sections = main.querySelectorAll("section.elementor-top-section");
      if (sections.length > 0) {
        const lastSection = sections[sections.length - 1];
        if (!lastSection.classList.contains("adobe-tracking-breadcrumbs")) {
          lastSection.classList.add("adobe-tracking-breadcrumbs");
        }
      }
    }
  }

  // Run initialization when DOM is ready
  if (document.readyState === "loading") {
    // If the DOM is still loading, add event listeners for when it's ready
    document.addEventListener("DOMContentLoaded", () => {
      initializeTracking();
      addBreadcrumbsTrackingClass();
    });
  } else {
    // If the DOM is already loaded, initialize tracking immediately
    initializeTracking();
    addBreadcrumbsTrackingClass();
  }
</script>

<script>
  // Helper function for conditional logging
  function debugLog(...args) {
    if (window.location.hostname !== "www.garantibbva.ro") {
      console.log(...args);
    }
  }

  // Wait for the chat widget to load
  const observeLanguageChanges = () => {
    debugLog("Attempting to find language menu...");
    const languageMenu = document.querySelector(
      ".druid__webchat__header__language-menu"
    );

    if (!languageMenu) {
      debugLog("Language menu not found, retrying in 1s...");
      setTimeout(observeLanguageChanges, 1000);
      return;
    }

    debugLog("Language menu found, attaching listener");

    // Add click listeners to language options
    languageMenu.addEventListener("click", (event) => {
      debugLog("Language menu clicked:", event.target);

      const languageOption = event.target.closest(".dropdown-item");
      if (!languageOption) {
        debugLog("Click was not on a language option");
        return;
      }

      // Get the selected language code
      const langCode = languageOption.getAttribute("data-lang");
      debugLog("Selected language code:", langCode);

      // Map language codes to readable names
      const languageMap = {
        "en-US": "English",
        ro: "Romanian",
      };

      const selectedLanguage = languageMap[langCode] || langCode;
      debugLog("Mapped language name:", selectedLanguage);

      // Push to Adobe data layer
      window.adobeDataLayer.push({
        event: "chatbot",
        _garantibanksa: {
          chatbot: {
            languageSelected: selectedLanguage,
          },
        },
      });

      debugLog("Pushed to Adobe data layer:", selectedLanguage);
    });

    debugLog("Language change listener attached");
  };

  // Function to handle chat visibility changes
  const handleChatVisibility = (chatBox) => {
    // Check initial state
    if (!chatBox.classList.contains("hide")) {
      debugLog("Chat is visible, initializing language observer...");
      observeLanguageChanges();
      return;
    }

    // Create observer for visibility changes
    const chatObserver = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        if (
          mutation.type === "attributes" &&
          mutation.attributeName === "class"
        ) {
          if (!chatBox.classList.contains("hide")) {
            debugLog("Chat became visible, initializing language observer...");
            observeLanguageChanges();
            chatObserver.disconnect();
          }
        }
      });
    });

    chatObserver.observe(chatBox, {
      attributes: true,
      attributeFilter: ["class"],
    });
    debugLog("Visibility observer attached");
  };

  // Initialize when DOM is ready
  const initChatObserver = () => {
    const chatBox = document.getElementById(
      "druid__minimizable__web-chat__chat-box"
    );
    if (chatBox) {
      handleChatVisibility(chatBox);
    } else {
      const domObserver = new MutationObserver(() => {
        const chatBox = document.getElementById(
          "druid__minimizable__web-chat__chat-box"
        );
        if (chatBox) {
          debugLog("Chat box found");
          handleChatVisibility(chatBox);
          domObserver.disconnect();
        }
      });

      domObserver.observe(document.body, {
        childList: true,
        subtree: true,
      });
    }
  };

  // Start the process
  initChatObserver();
</script>

<script>
  

  // Helper Functions

  function isDevelopmentOrStaging() {
    const hostname = window.location.hostname;
    return (
      hostname.includes("edicion-la83d4oj") ||
      hostname.includes("revision-la83d4oj")
    );
  }

  function debugLog(...args) {
    if (isDevelopmentOrStaging()) {
      console.log(...args);
    }
  }

  // Global error handler
  window.onerror = function (message, source, lineno, colno, error) {
    window.adobeDataLayer.push({
      event: "error",
      _garantibanksa: {
        error: {
          errorCode: error?.code || "JS-" + lineno,
          errorType: error?.name || "JavaScript Error",
          errorMessage: message || "Unknown error",
        },
      },
    });

    // Log to console for debugging (only in non-production)
    if (window.location.hostname !== "www.garantibbva.ro") {
      debugLog("Error tracked:", {
        message: message,
        source: source,
        lineno: lineno,
        colno: colno,
        error: error,
      });
    }
  };

  // Handle promise rejections
  window.addEventListener("unhandledrejection", function (event) {
    window.adobeDataLayer.push({
      event: "error",
      _garantibanksa: {
        error: {
          errorCode: "PROMISE-ERR",
          errorType: "Unhandled Promise Rejection",
          errorMessage: event.reason?.message || "Promise rejected",
        },
      },
    });
  });

  // Test the error tracking (only in non-production)
  if (isDevelopmentOrStaging()) {
    debugLog("Error tracking initialized");
  }
</script>

<script>
  const formNameMapping = {
    la83d4oj1679056518434: "Contact",
    la83d4oj1695045353870: "Application state",
    la83d4oj1693486400499: "Starea Aplicatiei",
    la83d4oj1680117258704: "Aplică pentru Pachet +",
    la83d4oj1705194263093: "Aplică pentru Bonus Card contactless",
    la83d4oj1705263361123: "Recomandă un partener",
    la83d4oj1705286006667: "Beneficiile partenerilor Bonus Card",
    la83d4oj1680116680222: "Aplică pentru cont curent",
    la83d4oj1680116456580: "Aplică Garanti BBVA Online - Persoane Fizice",
    la83d4oj1680251077677: "Aplică Garanti BBVA Online - IMM",
    la83d4oj1680117319210: "Aplică pentru un cont de economii",
    la83d4oj1680117391554: "Aplică pentru un depozit la termen",
    la83d4oj1680116842847: "Aplică pentru credit de nevoi personale",
    la83d4oj1680116901071: "Aplică pentru credit de nevoi personale cu ipotecă",
    la83d4oj1680117035588: "Aplică pentru credit imobiliar",
    la83d4oj1680117090618: "Aplică pentru overdraft",
    la83d4oj1677838123206: "Aplică pentru un cont curent IMM",
    la83d4oj1705277416865: "Devino partener",
    la83d4oj1728375909320: "Aplică pentru campania Se Poate",
  };
  // Helper Functions
  function isDevelopmentOrStaging() {
    const hostname = window.location.hostname;
    return (
      hostname.includes("edicion-la83d4oj") ||
      hostname.includes("revision-la83d4oj")
    );
  }

  function debugLog(...args) {
    if (isDevelopmentOrStaging()) {
      console.log(...args);
    }
  }

  // Form tracking class
  class FormTracker {
    constructor(form) {
      // Prevent multiple trackers on the same form
      if (form._hasTracker) {
        return;
      }
      form._hasTracker = true;

      this.form = form;
      this.formName = this.getFormName();
      this.lastAccessedField = null;
      this.enteredFields = new Set();
      this.hasStarted = false;
      this.hasSubmitted = false;
      this.setupListeners();
      debugLog("Tracker initialized for form:", this.formName);

      // Set up error message observer
      this.setupErrorObserver();

      // Add success URL check
      this.successUrl = "/iti-multumim-ca-ai-ales-serviciile-garanti-bbva";

      // Listen for success navigation
      this.setupSuccessListener();

      this.errorTrackingTimeout = 5000; // 5 seconds timeout between same error tracking
      this.trackedErrors = new Map(); // Track errors with timestamps
    }

    getFormName() {
      const formId = this.form.id || "";
      // Extract the unique ID part (everything after form_)
      const uniqueId = formId.replace("form_", "");
      return formNameMapping[uniqueId] || `Form ${formId}`;
    }

    setupListeners() {
      // Track form start
      this.form.addEventListener("focusin", (e) => this.handleFormStart(e), {
        once: true,
      });

      // Track field interactions
      this.form.addEventListener("focusin", (e) => this.handleFieldFocus(e));
      this.form.addEventListener("input", (e) => this.handleFieldInput(e));

      // Track form submission
      this.form.addEventListener("submit", (e) => this.handleFormSubmit(e));

      // Track form abandonment on page leave
      window.addEventListener("beforeunload", (e) =>
        this.handleFormAbandonment(e)
      );
    }

    handleFormStart(event) {
      if (!this.hasStarted) {
        this.hasStarted = true;
        if (window.adobeDataLayer) {
          window.adobeDataLayer.push({
            event: "formStart",
            _garantibanksa: {
              form: {
                formName: this.formName,
              },
            },
          });
          debugLog("Form Start:", this.formName);
        }
      }
    }

    handleFieldFocus(event) {
      if (
        event.target.tagName === "INPUT" ||
        event.target.tagName === "SELECT" ||
        event.target.tagName === "TEXTAREA"
      ) {
        this.lastAccessedField = event.target.name || event.target.id;
      }
    }

    handleFieldInput(event) {
      if (
        event.target.tagName === "INPUT" ||
        event.target.tagName === "SELECT" ||
        event.target.tagName === "TEXTAREA"
      ) {
        const fieldName = event.target.name || event.target.id;
        if (fieldName) {
          this.enteredFields.add(fieldName);
        }
      }
    }

    handleFormSubmit(event) {
      this.hasSubmitted = true;
      // Store the next URL before navigation
      localStorage.setItem("nextFormUrl", this.successUrl);

      if (window.adobeDataLayer) {
        window.adobeDataLayer.push({
          event: "formSubmit",
          _garantibanksa: {
            form: {
              formName: this.formName,
            },
          },
        });
        debugLog("Form Submit:", this.formName);
      }
    }

    handleFormAbandonment(event) {
      // Only track abandonment if the form was started but not submitted
      if (
        this.hasStarted &&
        !this.hasSubmitted &&
        this.enteredFields.size > 0
      ) {
        const enteredFieldsList = Array.from(this.enteredFields).join(" | ");
        const abandonmentData = {
          event: "formAbandonment",
          formName: this.formName,
          lastAccessedField: this.lastAccessedField,
          formFieldsEntered: enteredFieldsList,
        };

        // Push to adobeDataLayer
        if (window.adobeDataLayer) {
          window.adobeDataLayer.push({
            event: "formAbandonment",
            _garantibanksa: abandonmentData,
          });
          debugLog(
            "Form Abandonment:",
            this.formName,
            "Last field:",
            this.lastAccessedField
          );
          localStorage.setItem(
            "///formAbandonment",
            JSON.stringify({
              timestamp: new Date().toLocaleTimeString("en-US", {
                hour12: false,
              }),
              data: abandonmentData,
            })
          );
        }
      }
    }

    trackError(errorMessage) {
      const now = Date.now();
      const lastTracked = this.trackedErrors.get(errorMessage);

      // Only track if we haven't tracked this error recently
      if (!lastTracked || now - lastTracked > this.errorTrackingTimeout) {
        if (window.adobeDataLayer) {
          window.adobeDataLayer.push({
            event: "formErrors",
            _garantibanksa: {
              error: {
                formErrorMessage: errorMessage,
                formName: this.formName,
              },
            },
          });
          debugLog("Form Error:", errorMessage);
        }

        // Update the timestamp for this error
        this.trackedErrors.set(errorMessage, now);
      }
    }

    trackSuccess() {
      if (window.adobeDataLayer) {
        window.adobeDataLayer.push({
          event: "formSuccess",
          _garantibanksa: {
            form: {
              formName: this.formName,
            },
          },
        });
        debugLog("Form Success:", this.formName);
        localStorage.setItem(
          "///formSuccess",
          JSON.stringify({
            timestamp: new Date().toLocaleTimeString("en-US", {
              hour12: false,
            }),
            data: {
              formName: this.formName,
            },
          })
        );
      }
    }

    setupErrorObserver() {
      // Create observer for error messages
      const errorObserver = new MutationObserver((mutations) => {
        // Track processed error elements to prevent duplicates
        const processedErrors = new Set();

        mutations.forEach((mutation) => {
          if (mutation.type === "childList") {
            // Check for specific error messages
            const formElements = this.form.querySelectorAll("*");
            formElements.forEach((element) => {
              const text = element.textContent?.trim().replace(/\\/g, "");
              // Skip if we've already processed this element in this mutation batch
              if (text && !processedErrors.has(element)) {
                if (
                  text === 'Toate câmpurile marcate cu "*" sunt obligatorii' ||
                  text ===
                    "Trebuie să fiți de acord cu prelucrarea datelor dvs. cu caracter personal pentru a trimite formularul" ||
                  text ===
                    "Vă rugăm să selectați una dintre cele 2 opțiuni de sus" ||
                  text === 'All fields marked with "*" are mandatory' ||
                  text ===
                    "You must agree to process your personal data in order to submit the form"
                ) {
                  if (
                    element.style.display !== "none" &&
                    element.offsetParent !== null
                  ) {
                    // Track this individual error with cleaned text
                    this.trackError(text);
                    // Mark this element as processed
                    processedErrors.add(element);
                  }
                }
              }
            });
          }
        });
      });

      // Start observing the form for changes
      errorObserver.observe(this.form, {
        childList: true,
        subtree: true,
        characterData: true,
      });
    }

    setupSuccessListener() {
      // Listen for the navigation that happens after form submission
      window.addEventListener("beforeunload", () => {
        if (this.hasStarted && !this._successTracked) {
          const nextUrl = localStorage.getItem("nextFormUrl");
          if (nextUrl && nextUrl.includes(this.successUrl)) {
            this.trackSuccess();
            this._successTracked = true;
          }
        }
      });
    }
  }

  // Track which forms we've already initialized
  const initializedForms = new WeakSet();

  function initializeFormTracking() {
    // Watch for dynamically added forms
    const formObserver = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        if (mutation.type === "childList") {
          mutation.addedNodes.forEach((node) => {
            // Check if the added node is a form or contains forms
            if (
              node.nodeName === "FORM" ||
              (node.querySelectorAll &&
                node.querySelectorAll("form").length > 0)
            ) {
              const forms =
                node.nodeName === "FORM"
                  ? [node]
                  : node.querySelectorAll("form");
              forms.forEach((form) => {
                if (
                  form.id &&
                  form.id.includes("la83d4oj") &&
                  !initializedForms.has(form)
                ) {
                  initializedForms.add(form);
                  debugLog("Initializing tracker for new form:", form.id);
                  new FormTracker(form);
                }
              });
            }
          });
        }
      });
    });

    // Start observing the entire document
    formObserver.observe(document.body, {
      childList: true,
      subtree: true,
    });

    // Check for any existing forms
    const existingForms = document.querySelectorAll('form[id*="la83d4oj"]');
    existingForms.forEach((form) => {
      if (!initializedForms.has(form)) {
        initializedForms.add(form);
        debugLog("Initializing tracker for existing form:", form.id);
        new FormTracker(form);
      }
    });
  }

  // Only set up the initialization once
  if (!window._formTrackingInitialized) {
    window._formTrackingInitialized = true;

    // Ensure adobeDataLayer exists
    window.adobeDataLayer = window.adobeDataLayer || [];

    // Run initialization when DOM is ready
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initializeFormTracking);
    } else {
      initializeFormTracking();
    }

    // Additional safety net for late-loading forms
    window.addEventListener("load", initializeFormTracking);
  }
</script>

