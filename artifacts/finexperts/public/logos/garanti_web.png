#butonverde > div > div > a, #sliderhomepageedit > div > div > div.owl-stage-outer > div > div > article > div > div.wp-block-group > div > div > a#butonVerdeSlide{
    background-size: 210% 100%;
    background-position: 99%;
    background-repeat: no-repeat;
    transition: background-position .66667s cubic-bezier(.24,.22,.31,1.07);
    transition-duration: 0.66667s;
    transition-timing-function: cubic-bezier(0.24, 0.22, 0.31, 1.07);
    transition-delay: 0s;
    transition-property: background-position;
    background-image: linear-gradient(100deg,#027e7e 50%,#02a5a5 0);
    cursor: pointer;
    white-space: nowrap;
    text-overflow: ellipsis;
	
	}
	
	
	#butonAlbastruSlide{
	    border-radius: 2px;
	     padding: 17px 53px;
	    
  	     background-color: #1973b8;
    background-size: 210% 100%;
    background-position: 99%;
    background-repeat: no-repeat;
    transition: background-position .66667s cubic-bezier(.24,.22,.31,1.07);
    transition-duration: 0.66667s;
    transition-timing-function: cubic-bezier(0.24, 0.22, 0.31, 1.07);
    transition-delay: 0s;
    transition-property: background-position;
    background-image: linear-gradient(100deg,#072146 50%,#004481 0);
    cursor: pointer;
    overflow: hidden;
    text-overflow: ellipsis;
    color:white;
	}
	
	
	#butonAlbastruSlide:hover{
background-position: 0;
	}
	
	
	
	#butonverde > div > div > a:hover, #sliderhomepageedit > div > div > div.owl-stage-outer > div > div > article > div > div.wp-block-group > div > div > a#butonVerdeSlide:hover{
		    background-position: 0;
	}
	
	#butonVerde, .butonverde{
	     background-color: #5AC4C4;
    background-size: 210% 100%;
    background-position: 99%;
    background-repeat: no-repeat;
    transition: background-position .66667s cubic-bezier(.24,.22,.31,1.07);
    transition-duration: 0.66667s;
    transition-timing-function: cubic-bezier(0.24, 0.22, 0.31, 1.07);
    transition-delay: 0s;
    transition-property: background-position;
    background-image: linear-gradient(100deg,#027e7e 50%,#5AC4C4 0);
    cursor: pointer;
    white-space: nowrap;

    text-overflow: ellipsis;
	}
	
	#butonVerde:hover, .butonverde:hover{
	     background-position: 0;
	}
	
	
	#butonalbastrudeschis > div > div > a {
	     background-color: #1973b8;
    background-size: 210% 100%;
    background-position: 99%;
    background-repeat: no-repeat;
    transition: background-position .66667s cubic-bezier(.24,.22,.31,1.07);
    transition-duration: 0.66667s;
    transition-timing-function: cubic-bezier(0.24, 0.22, 0.31, 1.07);
    transition-delay: 0s;
    transition-property: background-position;
    background-image: linear-gradient(100deg,#004481 50%,#1973b8 0);
    cursor: pointer;
    overflow: hidden;
    text-overflow: ellipsis;
	}
	
	#butonalbastrudeschis > div > div > a:hover, #butonalbastrumeniu > div > div > a:hover{
		    background-position: 0!important;
	}
	
	#butonalbastrumeniu > div > div > a {
	     background-color: #004481;
    background-size: 210% 100%;
    background-position: 99%!important;
    background-repeat: no-repeat;
    transition: background-position .66667s cubic-bezier(.24,.22,.31,1.07);
    transition-duration: 0.66667s;
    transition-timing-function: cubic-bezier(0.24, 0.22, 0.31, 1.07);
    transition-delay: 0s;
    transition-property: background-position;
    background-image: linear-gradient(100deg,#072146 50%,#004481 0);
    cursor: pointer;
    overflow: hidden;
    text-overflow: ellipsis;
	}
	
	#butonalbastrumeniu > div > div{
	    max-height: 54px;
	}
	
	
	
	#animatiecallto > div > a .elementor-cta__bg-overlay{
	    background-color: transparent!important;
	    will-change: background-position;
    background-image: linear-gradient(-10deg,#043263B3 50%,transparent 0);
    background-size: 100% 300%;
    background-repeat: no-repeat;
    background-position: center 12%;
    transition: background-position .66667s cubic-bezier(.61,0,.39,1);
	}
	
	#animatiecallto > div > a:hover .elementor-cta__bg-overlay{
	    transition-delay: 0ms;
    background-position: center 88%;
	}
	
	#animatiecallto > div > a:hover .elementor-cta__content{
	    padding-top: 80px!important
	}/* End custom CSS */
