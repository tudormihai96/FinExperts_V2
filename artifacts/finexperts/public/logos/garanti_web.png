<script>
  // Function to check if we're in a development or staging environment
  function isDevelopmentOrStaging() {
    const hostname = window.location.hostname;
    return (
      hostname.includes("edicion-la83d4oj") ||
      hostname.includes("revision-la83d4oj")
    );
  }

  // Wrapper for console.log that only logs in development or staging
  function debugLog(...args) {
    if (isDevelopmentOrStaging()) {
      console.log(...args);
    }
  }

  // Function to extract sections from URL
  function extractSectionsFromURL() {
    var path = window.location.pathname.split("/").filter(Boolean);
    var language = path[0] === "en" ? path.shift() : "ro"; // Remove 'en' if it's the first element
    var pageNameFromURL = path.pop() || null; // Remove and store the last element as page name
    return {
      language: language,
      siteSection: path[0] || null,
      subSection1: path[1] || null,
      subSection2: path[2] || null,
      pageNameFromURL: pageNameFromURL
        ? pageNameFromURL.replace(/\.html$/, "")
        : null, // Remove .html if present
    };
  }

  // Function to get page name from URL
  function getPageNameFromURL() {
    try {
      // Check if it's a 404 page
      var metaTitle = document.querySelector('meta[name="title"]');
      debugLog("Meta title element:", metaTitle);

      if (metaTitle) {
        var metaContent = metaTitle.getAttribute("content");
        debugLog("Meta title content:", metaContent);

        if (metaContent && metaContent.includes("Page not found")) {
          debugLog("404 page detected");
          return "404";
        }
      }

      var path = window.location.pathname.split("/").filter(Boolean);
      debugLog("URL path segments:", path);

      // Return 'home' only when path is exactly '/en/individuals'
      if (path.length === 2 && path[0] === "en" && path[1] === "individuals") {
        debugLog("Home page detected");
        return "home";
      }

      // Check if path is empty or has no last element
      if (!path.length) {
        debugLog("Empty path detected");
        return "home";
      }

      // Get the last segment of the path and remove .html if present
      var lastSegment = path[path.length - 1];
      if (!lastSegment) {
        debugLog("No last segment found");
        return "home";
      }

      var pageName = lastSegment.replace(/\.html$/, "");
      debugLog("Page name determined:", pageName);
      return pageName;
    } catch (error) {
      console.error("Error in getPageNameFromURL:", error);
      return "error";
    }
  }

  // Function to get previous page name
  function getPreviousPageName() {
    var previousPageName = sessionStorage.getItem("currentPageName");
    if (!previousPageName) {
      if (document.referrer) {
        var referrerURL = new URL(document.referrer);
        if (referrerURL.hostname === window.location.hostname) {
          return "internal";
        } else {
          return "external";
        }
      } else {
        return "external";
      }
    }
    return previousPageName;
  }

  // Function to set current page name in sessionStorage
  function setCurrentPageName(pageName) {
    sessionStorage.setItem("currentPageName", pageName);
  }

  // Function to get platform info
  function getPlatformInfo() {
    var ua = navigator.userAgent;
    var deviceType = /(tablet|ipad|playbook|silk)|(android(?!.*mobi))/i.test(ua)
      ? "tablet"
      : /Mobile|iP(hone|od)|Android|BlackBerry|IEMobile|Kindle|Silk-Accelerated|(hpw|web)OS|Opera M(obi|ini)/.test(
          ua
        )
      ? "mobile"
      : "desktop";
    var os = /Windows/i.test(ua)
      ? "Windows"
      : /Mac OS X/.test(ua)
      ? "macOS"
      : /Linux/.test(ua)
      ? "Linux"
      : /Android/.test(ua)
      ? "Android"
      : /iOS|iPhone|iPad|iPod/.test(ua)
      ? "iOS"
      : "Unknown OS";
    var browser = /Chrome/.test(ua)
      ? "Chrome"
      : /Firefox/.test(ua)
      ? "Firefox"
      : /Safari/.test(ua)
      ? "Safari"
      : /MSIE|Trident/.test(ua)
      ? "Internet Explorer"
      : /Edge/.test(ua)
      ? "Edge"
      : /Opera|OPR/.test(ua)
      ? "Opera"
      : "Unknown Browser";
    return deviceType + " | " + os + " | " + browser;
  }

  // Initialize Adobe Data Layer
  window.adobeDataLayer = window.adobeDataLayer || [];

  // Get all required information
  var urlSections = extractSectionsFromURL();
  var currentPageName = getPageNameFromURL();

  // Push data to Adobe Data Layer
  window.adobeDataLayer.push({
    event: "pageload",
    web: {
      webPageDetails: {
        name: currentPageName,
        previousPage: getPreviousPageName(),
        siteSection: urlSections.siteSection,
        site: "www.garantibbva.ro",
        platform: getPlatformInfo(),
        language: urlSections.language,
        subSection1: urlSections.subSection1,
        subSection2: urlSections.subSection2,
      },
    },
  });

  // Set current page name for next navigation
  setCurrentPageName(currentPageName);

  // Function to dynamically load the Adobe script
  function loadAdobeScript() {
    var currentHost = window.location.hostname;
    var scriptSrc = "";
    var environment = "";

    if (currentHost.includes("edicion-la83d4oj")) {
      scriptSrc =
        "https://assets.adobedtm.com/782fcaf72dc9/803ba2fdd68f/launch-961372cccea5-development.min.js";
      environment = "Development";
    } else if (currentHost.includes("revision-la83d4oj")) {
      scriptSrc =
        "https://assets.adobedtm.com/782fcaf72dc9/803ba2fdd68f/launch-02dcb0c8a410-staging.min.js";
      environment = "Staging";
    } else if (currentHost.includes("garantibbva.ro")) {
      scriptSrc =
        "https://assets.adobedtm.com/782fcaf72dc9/803ba2fdd68f/launch-ce0a1c88950f.min.js";
      environment = "Production";
    } else {
      if (isDevelopmentOrStaging()) {
        console.warn(
          "No matching script found for the current hostname:",
          currentHost
        );
      }
      return; // Exit if no matching URL
    }

    debugLog(
      "Loading Adobe script for " +
        environment +
        " environment on " +
        currentHost
    );

    var script = document.createElement("script");
    script.src = scriptSrc;
    script.async = true;
    script.onload = function () {
      debugLog(
        "Adobe script for " + environment + " environment loaded successfully"
      );
    };
    script.onerror = function () {
      if (isDevelopmentOrStaging()) {
        console.error(
          "Failed to load Adobe script for " + environment + " environment"
        );
      }
    };
    document.head.appendChild(script);
  }

  // Call the function when the DOM is fully loaded
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", loadAdobeScript);
  } else {
    loadAdobeScript();
  }
</script>

