				<div class="elementor-element elementor-element-8fcc3e5 elementor-widget elementor-widget-html" data-id="8fcc3e5" data-element_type="widget" data-e-type="widget" data-widget_type="html.default">
				<div class="elementor-widget-container">
					<script>
  //   < ---------------------- ADOBE ANALYTICS ------------------------------->

  const productionHostname45 = "www.garantibbva.ro";

  // Helper Functions
  function determineLinkType(element) {
    if (element.hasAttribute("download")) {
      return "download";
    } else if (
      element.hostname.includes(window.location.hostname) ||
      element.hostname.includes(productionHostname45)
    ) {
      return "other";
    } else {
      return "exit";
    }
  }

  function getLastUrlParameter() {
    const pathArray = window.location.pathname.split("/");
    return (
      pathArray[pathArray.length - 1] ||
      pathArray[pathArray.length - 2] ||
      "home"
    );
  }

  function isDevelopment() {
    return !window.location.hostname.includes(productionHostname45);
  }

  // Main tracking function
  function trackFooterClick(event) {
    const clickedElement = event.target.closest("a");
    if (!clickedElement) return;

    const pageName = getLastUrlParameter();
    let linkName = clickedElement.textContent.trim();

    // Social media URL mapping
    const imagesUrlMap = {
      "https://www.facebook.com/GarantiBBVARomania/":
        "GarantiBBVA Facebook profile",
      "https://twitter.com/GarantiBBVARo": "GarantiBBVA X Profile",
      "https://www.instagram.com/garantibbva_romania/":
        "GarantiBBVA Instagram profile",
      "https://www.linkedin.com/company/garanti-bbva-romania/":
        "GarantiBBVA LinkedIn profile",
      "https://www.youtube.com/c/GarantiBBVARomania":
        "GarantiBBVA YouTube profile",
      "https://anpc.ro/ce-este-sal/": "ANPC",
    };

    // Check if the clicked URL matches any social media URLs
    if (imagesUrlMap[clickedElement.href]) {
      linkName = imagesUrlMap[clickedElement.href];
    } else {
      // Existing logo image handling
      const logoImage = clickedElement.querySelector("img");
      if (logoImage) {
        if (
          logoImage.src.includes("/wp-content/uploads/2023/01/Layer-2.png") ||
          logoImage.src.includes("/wp-content/uploads/2023/01/1200-1.svg")
        ) {
          linkName = "Garanti BBVA LOGO";
        } else {
          linkName = logoImage.alt || "Logo Image";
        }
      }
    }

    const linkUrl = clickedElement.href || "";
    const linkType = determineLinkType(clickedElement);

    const dataLayerObject = {
      event: "footerClick",
      web: {
        webPageDetails: {
          name: pageName,
        },
        webInteraction: {
          name: linkName,
          linkPosition: "footer",
          type: linkType,
          URL: linkUrl,
        },
      },
    };

    // Push to adobeDataLayer and log
    if (window.adobeDataLayer) {
      window.adobeDataLayer.push(dataLayerObject);
      if (isDevelopment()) {
        console.log("Pushed to Adobe Data Layer:", dataLayerObject);
      }
    } else {
      if (isDevelopment()) {
        console.error("Adobe Data Layer not found");
      }
    }

    // Conditional console log
    if (isDevelopment()) {
      console.log("Footer Click:", dataLayerObject);
    }
  }

  // Initialize tracking
  function initializeTracking() {
    const footer = document.querySelector(
      ".elementor.elementor-962.elementor-location-footer"
    );
    if (footer) {
      footer.addEventListener("click", trackFooterClick);
      if (isDevelopment()) {
        console.log("Footer tracking initialized");
      }
    } else {
      if (isDevelopment()) {
        console.error("Footer element not found");
      }
    }
  }

  // Run initialization when DOM is ready and again after window load
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializeTracking);
  } else {
    initializeTracking();
  }
  window.addEventListener("load", initializeTracking);
</script>
