        ];
      
        for (let i = 0; i < arr1.length; i++) {
          if (currentUrl === arr1[i]) {
            window.location.replace(arr2[i]);
            return;
          }
        }
      
        const regex = /(\/a\/).*/;
        const match = currentUrl.match(regex);
      
        if (match) {
          const newUrl = currentUrl.substring(0, match.index);
          window.location.replace(newUrl);
        }
      }
      
      removeAndRedirect();
    </script>				</div>
