						<div class="elementor-container elementor-column-gap-no">
					<div class="elementor-column elementor-col-100 elementor-top-column elementor-element elementor-element-6dfda4c" data-id="6dfda4c" data-element_type="column" data-e-type="column">
			<div class="elementor-widget-wrap elementor-element-populated">
						<div class="elementor-element elementor-element-87bf483 elementor-widget elementor-widget-html" data-id="87bf483" data-element_type="widget" data-e-type="widget" data-widget_type="html.default">
				<div class="elementor-widget-container">
					<script>
    jQuery(document).ready(function($) {
  const targetNodes = document.querySelectorAll('.elementor-widget-accordion > div > div > div:nth-child(2) > div');

// Create a new instance of the MutationObserver
const observer = new MutationObserver((mutationsList, observer) => {
  // Loop through all mutations that have been observed
  for (const mutation of mutationsList) {
    // If the mutation is a change to the class attribute
    if (mutation.attributeName === 'class') {
      const targetElement = mutation.target;
      // If the target element now has the elementor-active class
      if (targetElement.classList.contains('elementor-active')) {
        // Hide certain elements when a tab is expanded
        console.log('test')
        document.querySelector('#menumobilestyle > div > div > div.elementor-tabs-wrapper').style.display = "none";
        document.querySelectorAll('.elementor-tab-title[aria-expanded="false"]').forEach((node) => {
          node.style.display = "none";
            });
             document.querySelectorAll('#sectiunefacuta').forEach((node) => {
          node.style.display = "none";
           
        });
        document.querySelectorAll('#sectiuneWrapper:not(:has( div > div > div > #sectiunespeciala > div > div > div:nth-child(2) > .elementor-tab-title.elementor-active))').forEach((node) => {
          node.style.display = "none";
           
        });
        
        
      } else {
        // Show certain elements when a tab is collapsed
        document.querySelector('#menumobilestyle > .elementor-widget-container > .elementor-tabs > div.elementor-tabs-wrapper').style.display = "flex";
       
        document.querySelectorAll('.elementor-accordion-item > .elementor-tab-title[aria-expanded="false"]').forEach((node) => {
          node.style.display = "flex";
        });
           document.querySelectorAll('#sectiunefacuta').forEach((node) => {
          node.style.display = "block";
           
        });
        document.querySelectorAll('#menumobilestyle > div > div > div.elementor-tabs-wrapper > div').forEach((node) => {
          node.style.display = "block";
          document.querySelectorAll('#sectiuneWrapper:not(:has( div > div > div > #sectiunespeciala > div > div > div:nth-child(2) > .elementor-tab-title.elementor-active))').forEach((node) => {
          node.style.display = "block";
           
        });
           
        });
      }
    }
  }
});

// Configure the observer to watch for changes to the class attribute
const observerConfig = {
  attributes: true,
  attributeFilter: ['class'],
};

// Start observing each target node for changes
targetNodes.forEach((node) => {
  observer.observe(node, observerConfig);
});
  });
</script>				</div>
				</div>
