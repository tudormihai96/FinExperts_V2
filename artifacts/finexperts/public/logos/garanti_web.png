        localStorage.setItem('queryParameter', window.location.search);
    }
}
</script>

<script>
    function removeAndRedirect() {
        const currentUrl = window.location.href;
        const arr1 = [  
          'https://www.garantibbva.ro/en/individuals/savings-accounts/bonus-economus/',
          'https://www.garantibbva.ro/en/individuals/savings-accounts/',
          'https://www.garantibbva.ro/en/sme-and-pfa/savings-accounts/',
          'https://www.garantibbva.ro/en/sme-and-pfa/bonus-economus/',
          'https://www.garantibbva.ro/persoane-fizice/conturi-de-economii/bonus-economus/',
            'https://www.garantibbva.ro/persoane-fizice/conturi-de-economii/',
            'https://www.garantibbva.ro/imm-si-pfa/conturi-de-economii/',
            'https://www.garantibbva.ro/imm-si-pfa/conturi-de-economii/bonus-economus/',
          
        
        
      ];

  

      const arr2 = [     
          'https://www.garantibbva.ro/en/individuals/savings-accounts/economus/',
          'https://www.garantibbva.ro/en/individuals/savings-accounts/economus/',
          'https://www.garantibbva.ro/en/sme-and-pfa/savings-accounts/economus/',
          'https://www.garantibbva.ro/en/sme-and-pfa/savings-accounts/economus/',
           'https://www.garantibbva.ro/persoane-fizice/conturi-de-economii/economus/',
            'https://www.garantibbva.ro/persoane-fizice/conturi-de-economii/economus/',
            'https://www.garantibbva.ro/imm-si-pfa/conturi-de-economii/economus/',
            'https://www.garantibbva.ro/imm-si-pfa/conturi-de-economii/economus/',
         
      ];
      
        for (let i = 0; i < arr1.length; i++) {
          if (currentUrl === arr1[i]) {
            window.location.replace(arr2[i]);
            return;
          }
        }
      
        const regex = /(\/a\/).*/;
        const match = currentUrl.match(regex);
      
        if (match) {
          const newUrl = currentUrl.substring(0, match.index);
          window.location.replace(newUrl);
        }
      }
      
      removeAndRedirect();
    </script>
    



