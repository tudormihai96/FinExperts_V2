  border:1px solid #D3D3D3!important;
}
.export-buttons{
  display: flex!important;
  height: 110px!important;
  align-content: center!important;
  border-top: 1px solid #D3D3D3!important
}
table{
  width: 759px!important;
}


th{
    padding:0!important;
    vertical-align: middle!important;
}
.export-buttons-wrapper{
  display: flex!important;
  align-items: center!important;
  max-width: 764px!important;
  width: 100%!important;
  margin: auto!important;
  gap:52px!important;
}

.wrapper-results-and-buttons{
  display: flex!important;
    flex-direction: column!important;
    width: 100%!important;
    flex-wrap: nowrap!important;
    justify-content: space-between!important;
}

.export-buttons-wrapper > button{
  font-family: "BentonSansBBVA-Medium", Sans-serif!important;
  background:transparent!important;
  border:none!important;
  color:#1973B8!important;
  font-size:15px!important;
  display: flex!important;
  align-items: center!important;
  gap:1rem!important;
  cursor: pointer!important;
}
.export-buttons-wrapper > button:nth-child(1):before{
  content: url(https://www.garantibbva.ro/wp-content/uploads/2023/02/pdf.svg);
  height: 22px;
  width: 16px;
}

.export-buttons-wrapper > button:nth-child(2):before{
  content: url(
https://www.garantibbva.ro/wp-content/uploads/2023/02/excel.svg);
height: 22px;
width: 16px;
}

table{
  border-collapse: collapse!important;
  max-width: 759px!important;
  margin: auto!important;
}

tr:nth-child(3n+3){
  background: #F4F4F4!important;
}
tbody > tr > th {
  
  height: 48px!important;
  background-color: #004481!important;
  color:white!important;
  font-family: "BentonSansBBVA-Medium", Sans-serif!important;
}
tbody > tr > td{
  padding:15px 0px!important;
  font-family: "BentonSansBBVA-Book", Sans-serif!important;
  color:#666666!important
}

tbody > *{
  font-size: 15px!important;
}

#creditSummary{
  background:#F4F4F4!important;
  max-width: 1180px!important;
  margin: auto!important;
  padding: 9px 0px!important;
  margin-bottom:2rem!important;
}

#creditSummaryWrapper{
  display: grid!important;
  grid-template-columns: repeat(4, 1fr)!important;
  grid-row-gap:1px!important;
  max-width: 767px!important;
  margin:auto!important;
  background: #D3D3D3!important;
 
  
 
}


#Result{
  max-height: 286px!important;
  overflow: auto!important;
  max-width: 764px!important;
  margin: 0 auto!important;
  width: 100%!important;
  margin-bottom: 130px!important;;

}
#creditSummaryWrapper > div{
  background:#F4F4F4!important;
  padding:8px!important;
}
#creditSummaryWrapper > div > h2{
  font-family: "BentonSansBBVA-Book", Sans-serif!important;
  font-size:13px!important;
  color:#666666!important;
  margin: 0px 0px 4px 0px!important;
}

#creditSummaryWrapper > div > span{
  font-family: "BentonSansBBVA-Medium", Sans-serif!important;
  font-size:18px!important;
}

.elementor-element-18bf9f1 > div{
    height: 100%
}
@media screen and (min-width: 1252px) {
.export-buttons-wrapper > button{
    padding:0;
}
    
}

@media screen and (max-width: 1252px) {
  #creditSummaryWrapper{
    display: grid!important;
    grid-template-columns: repeat(2, 1fr)!important;
    grid-row-gap:1px!important;
    max-width: 767px!important;
    margin:auto!important;
    background: #D3D3D3!important;
   
    
   
  }

}/* End custom CSS */
