					<script>
    window.addEventListener('load', function(){
        var breadCrumbsLink = document.querySelector('#mappingpage > div > ul > li:nth-child(1) > a');
        var breadCrumbsText = document.querySelector('#mappingpage > div > ul > li:nth-child(1) > a > span');

        var currentLanguage = document.documentElement.lang;

        if (breadCrumbsText && breadCrumbsLink) {
            if (localStorage.getItem('breadCrumbs') === "pf") {
                breadCrumbsLink.setAttribute('href', 'https://www.garantibbva.ro/');

                if (currentLanguage === "ro-RO") {
                    breadCrumbsText.textContent = "Persoane Fizice";
                } else {
                    breadCrumbsText.textContent = "Individuals";
                }
            }

            if (localStorage.getItem('breadCrumbs') === "corporate") {
                breadCrumbsLink.setAttribute('href', 'https://www.garantibbva.ro/corporate');

                if (currentLanguage === "ro-RO") {
                    breadCrumbsText.textContent = "Corporate";
                } else {
                    breadCrumbsText.textContent = "Corporate";
                }
            }

            if (localStorage.getItem('breadCrumbs') === "immPfa") {
                breadCrumbsLink.setAttribute('href', 'https://www.garantibbva.ro/imm-si-pfa/');

                if (currentLanguage === "ro-RO") {
                    breadCrumbsText.textContent = "IMM și PFA";
                } else {
                    breadCrumbsText.textContent = "SME and PFA";
                }
            }
        }
    });
</script>
<script>
let popupInterval = null;

function observePopup(popup) {
  // Check the display style of the popup element periodically
  popupInterval = setInterval(() => {
    const displayStyle = popup.style.display;
    if (displayStyle !== 'none') {
      // If the popup is visible, disable scrolling on the body
       document.body.style.overflow = 'hidden';
           document.body.style.maxWidth = 'calc(100% - 10px)';
      // Enable scrolling within the popup element
      popup.style.overflow = 'auto';
    } else {
      // If the popup is hidden, re-enable scrolling on the body
      document.body.style.overflow = 'auto';
      document.body.style.maxWidth = '100%'
  
    }
  }, 100);
}

// Create a new MutationObserver to observe changes to the body's child nodes
const bodyObserver = new MutationObserver((mutationsList) => {
  for (const mutation of mutationsList) {
    if (mutation.type === 'childList') {
      for (const addedNode of mutation.addedNodes) {
        if (addedNode.id === 'elementor-popup-modal-17013') {
          // If #elementor-popup-modal-17013 has been added, observe its display style
          clearInterval(popupInterval);
          observePopup(addedNode);
        }
      }
    }
  }
});

// Start observing changes to the body's child nodes
bodyObserver.observe(document.body, { childList: true });

// Call observePopup on any existing #elementor-popup-modal-17013 elements
const existingPopup = document.querySelector('#elementor-popup-modal-17013');
if (existingPopup) {
  observePopup(existingPopup);
}


</script>

<script>
    const targetNode = document.querySelector('body');

const observer = new MutationObserver((mutationsList) => {
  for (const mutation of mutationsList) {
    if (mutation.type === 'attributes' && mutation.attributeName === 'class' && mutation.target.classList.contains('jet-menu-item')) {
      if (mutation.target.classList.contains('jet-menu-hover')) {
     document.body.style.overflow = 'hidden';
     document.body.style.maxWidth = 'calc(100% - 10px)';
      } else {
        document.body.style.overflow = '';
         document.body.style.maxWidth = ''
      }
    }
  }
});

const config = { attributes: true, subtree: true };
observer.observe(targetNode, config);

</script>

