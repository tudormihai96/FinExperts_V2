			<div class="elementor-widget-wrap elementor-element-populated">
						<div class="elementor-element elementor-element-17299e7 elementor-widget elementor-widget-heading" data-id="17299e7" data-element_type="widget" data-e-type="widget" data-widget_type="heading.default">
				<div class="elementor-widget-container">
					<h2 class="elementor-heading-title elementor-size-default">Costuri și taxe</h2>				</div>
				</div>
				<div class="elementor-element elementor-element-18bf9f1 elementor-widget elementor-widget-html" data-id="18bf9f1" data-element_type="widget" data-e-type="widget" data-widget_type="html.default">
				<div class="elementor-widget-container">
					<script type="text/javascript" src="https://unpkg.com/xlsx@0.15.1/dist/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/1.5.3/jspdf.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.4/moment.min.js"></script>
<div id="creditSummary">
    <div id="creditSummaryWrapper">
        <div class="valoarea-ratei">
            <h2>Valoarea ratei:</h2>
            <span></span>
        </div>
        <div class="perioada">
            <h2>Perioada:</h2>
            <span></span>
        </div>
        <div class="comision-lunar">
            <h2>Comision lunar:</h2>
            <span></span>
        </div>
        <div class="comision-analiza">
            <h2>Comision analiză:</h2>
            <span></span>
        </div>
        <div class="comision-evaluare">
            <h2>Comision evaluare:</h2>
            <span></span>
        </div>
        <div class="rata-dobanzii">
            <h2>Rata dobânzii:</h2>
            <span></span>
        </div>
        <div class="valoarea-totala-de-plata">
            <h2>Valoarea totală de plată:</h2>
            <span></span>
        </div>
        <div class="dae">
            <h2>Dobânda anuală efectivă:</h2>
            <span></span>
        </div>
    </div>
</div>
<div class="wrapper-results-and-buttons">
    <div id="Result"></div>
    <div class="export-buttons">
        <div class="export-buttons-wrapper">
            <button onclick="exportWithoutSepcialCharacters('Result')">
                Descarcă PDF
            </button>
            <button onclick="exportToExcel('xlsx')">Descarcă Excel</button>
        </div>
    </div>
</div>

<script language="javascript">
    var wwOpenInstalled;
    if (wwOpenInstalled || parent.wwOpenInstalled) {
        if (window.Event) {
            document.captureEvents(Event.MOUSEUP);
        }
        document.onmouseup = parent.wwOpenInstalled
            ? parent.wwOnMouseUp
            : wwOnMouseUp;
    }
</script>
<script>
    function formatNumberValue(value, thousandsSeparator = true) {
        let result = Number.parseFloat(value).toFixed(2).replace(".", ",");
        if (thousandsSeparator) {
            result = result.replace(/\B(?=(\d{3})+(?!\d))/g, ".");
        }
        return result;
    }

    console.log("localStorageObject", localStorageObject);
    var monthText = "Lună";
    var data = "Dată";
    var balanta = "Principal";
    var interestText = "Dobândă";
    var comLunar = "Comision<br/>Lunar";
    var mp = "Total Plată<br/>Lunară";
    var totalAmount = "Sold Credit";
    var localStorageObject = localStorage.getItem("localStorageObject");
    var localStorageObject = JSON.parse(localStorageObject);
    var balance = parseFloat(localStorage.getItem("balance"));
    var valoareCredit = parseFloat(localStorage.getItem("balance"));
    var terms = parseInt(localStorage.getItem("duration"));
    var durataCredit = parseInt(localStorage.getItem("duration"));
    var dobandaFixa = localStorage.getItem("interestRate");
    var hasSalary = JSON.parse(localStorage.getItem("hasSalary"));
    var is3YFixed = JSON.parse(localStorage.getItem("is3YFixed"));
    var is5YFixed = JSON.parse(localStorage.getItem("is5YFixed"));
    var values = [];
    var dates = [];
    var DAE;
    var currency = localStorage.getItem("currency");
    var tipCredit = localStorage.getItem("tipCredit");
    var creditTypeForCostsTaxes = localStorage.getItem("creditTypeForCostsTaxes");

    var componenta_prima_imobil_procent = parseFloat(
        localStorageObject.componenta_prima_imobil_procent
    ); // problem calculate gpl plus
    var stergereRon = parseFloat(localStorageObject.stergere_ron);
    var stergereEuro = parseFloat(localStorageObject.stergere_euro);
    var comisionLunar = parseFloat(localStorageObject.comision_lunar);
    var comisionLunarEuro = parseFloat(localStorageObject.comision_lunar_eur);
    var comisionEvaluare = parseFloat(localStorageObject.comision_evaluare);
    var comisionAnalizaRon = parseFloat(localStorageObject.comision_analiza);
    var comisionAnalizaEuro = parseFloat(
        localStorageObject.comision_analiza_euro
    );
    var cursEuro = parseFloat(localStorageObject.curs_euro);
    var componentaPrimaImobilProcent =
        parseFloat(localStorageObject.componenta_prima_imobil_procent) / 100;
    var componentaPrimaImobil = parseFloat(
        localStorageObject.componenta_prima_imobil
    );
    var reinnoire = parseFloat(localStorageObject.reinnoire);
    var indice;
    var marja;
    var firstMonthRate = 0;
    var comisionAnalizaToDisplay = `${currency === "RON" ? comisionAnalizaRon : comisionAnalizaEuro
        }`;
    var asigurareCasa;
    var comisionEvaluareConverit = 0;
    var reinnoireConvertit = 0;

    if (tipCredit === "HL") {
        if (currency === "RON") {
            asigurareCasa =
                componentaPrimaImobil + (componentaPrimaImobilProcent * balance) / 0.75;
            reinnoireConvertit = reinnoire;
        } else {
            asigurareCasa =
                componentaPrimaImobil / cursEuro +
                (componentaPrimaImobilProcent * balance) / 0.65;
            reinnoireConvertit = reinnoire / cursEuro;
        }
    }

    if (tipCredit === "GPLPlus") {
        if (currency === "RON") {
            asigurareCasa =
                componentaPrimaImobil + (componentaPrimaImobilProcent * balance) / 0.75;
            reinnoireConvertit = reinnoire;
        } else {
            asigurareCasa =
                componentaPrimaImobil / cursEuro +
                (componentaPrimaImobilProcent * balance) / 0.75;
            reinnoireConvertit = reinnoire / cursEuro;
        }
    }
    if (!(tipCredit === "GPL")) {
        if (currency === "RON") {
            comisionEvaluareConverit = comisionEvaluare;
        } else {
            comisionEvaluareConverit = comisionEvaluare / cursEuro;
        }
    }

    if (currency == "RON" && hasSalary == true) {
        indice = parseFloat(localStorageObject.Indice_RON_variabila_salariu);
        marja = parseFloat(localStorageObject.Marja_RON_variabila_salariu);
    }
    if (currency == "RON" && hasSalary == false) {
        indice = parseFloat(localStorageObject.Indice_RON_variabila_fara_salariu);
        marja = parseFloat(localStorageObject.Marja_RON_variabila_fara_salariu);
    }
    if (currency == "EUR" && hasSalary == true) {
        indice = parseFloat(localStorageObject.Indice_EUR_variabila_salariu);
        marja = parseFloat(localStorageObject.Marja_EUR_variabila_salariu);
    }
    if (currency == "EUR" && hasSalary == false) {
        indice = parseFloat(localStorageObject.Indice_EUR_variabila_fara_salariu);
        marja = parseFloat(localStorageObject.Marja_EUR_variabila_fara_salariu);
    }

    if (currency == "RON") {
        comisionLunarCurrency = comisionLunar;
    } else {
        comisionLunarCurrency = comisionLunarEuro;
    }

    function XIRR(values, dates, guess) {
        var irrResult = function (values, dates, rate) {
            var r = rate + 1;
            var result = values[0];
            for (var i = 1; i < values.length; i++) {
                result +=
                    values[i] /
                    Math.pow(r, moment(dates[i]).diff(moment(dates[0]), "days") / 365);
            }
            return result;
        };

        var irrResultDeriv = function (values, dates, rate) {
            var r = rate + 1;
            var result = 0;
            for (var i = 1; i < values.length; i++) {
                var frac = moment(dates[i]).diff(moment(dates[0]), "days") / 365;
                result -= (frac * values[i]) / Math.pow(r, frac + 1);
            }
            return result;
        };
        var positive = false;
        var negative = false;
        for (var i = 0; i < values.length; i++) {
            if (values[i] > 0) positive = true;
            if (values[i] < 0) negative = true;
        }
        if (!positive || !negative) return "#NUM!";
        var guess = typeof guess === "undefined" ? 0.1 : guess;
        var resultRate = guess;
        var epsMax = 1e-10;
        var iterMax = 360;
        var newRate, epsRate, resultValue;
        var iteration = 0;
        var contLoop = true;
        do {
            resultValue = irrResult(values, dates, resultRate);
            newRate =
                resultRate - resultValue / irrResultDeriv(values, dates, resultRate);
            epsRate = Math.abs(newRate - resultRate);
            resultRate = newRate;
            contLoop = epsRate > epsMax && Math.abs(resultValue) > epsMax;
        } while (contLoop && ++iteration < iterMax);

        if (contLoop) return "#NUM!";
        return resultRate;
    }

    function getValues() {
        var interestRate = parseFloat(dobandaFixa / 100.0);

        var div = document.getElementById("Result");
        div.innerHTML = "";
        var balVal = validateInputs(balance);
        var intrVal = validateInputs(interestRate);

        if (balVal && intrVal) {
            div.innerHTML += amort(balance, interestRate, terms);
        } else {
            div.innerHTML += "Please Check your inputs and retry - invalid values.";
        }
    }

    function amort(balance, interestRate, terms) {
        console.log("DEBUG - Starting amort calculation with:", {
            balance: balance,
            interestRate: interestRate,
            terms: terms,
        });
        var tipRambursareOption = localStorage.getItem("tipRambursareOption");
        var monthlyRate = interestRate / 12;
        var payment;
        if (tipRambursareOption === "descrescatoare") {
            payment = balance / terms;
        }
        if (tipRambursareOption === "egale") {
            payment =
                balance * (monthlyRate / (1 - Math.pow(1 + monthlyRate, -terms)));
        }

        //new line
        var inregistrare = 0;
        var stergere = 0;
        var comisionAnaliza = 0;

        var result =
            '<table style="width:100%" border=\'1\' id = "tbl_exporttable_to_xls" class="table table-bordered"><tr><th> ' +
            monthText +
            "</th><th>" +
            data +
            "</th><th>" +
            balanta +
            "</th>" +
            "<th>" +
            interestText +
            "</th><th>" +
            comLunar +
            "</th><th>" +
            mp +
            "</th>" +
            "</th><th>" +
            totalAmount +
            "</th>";
        if (currency === "RON") {
            if (tipCredit === "GPL") {
                values.push(
                    parseFloat(
                        (-(
                            balance -
                            comisionAnalizaRon -
                            parseFloat(localStorageObject.intregistrare_ron)
                        )).toFixed(2)
                    )
                );
            } else {
                // Debug the components of the calculation
                console.log("DEBUG - Initial negative cash flow components:", {
                    balance: balance,
                    comisionAnalizaRon: comisionAnalizaRon,
                    intregistrare_ron: parseFloat(localStorageObject.intregistrare_ron),
                    asigurareCasa: asigurareCasa,
                    comisionEvaluareConverit: comisionEvaluareConverit,
                    calculatedValue: -(
                        balance -
                        comisionAnalizaRon -
                        parseFloat(localStorageObject.intregistrare_ron) -
                        asigurareCasa -
                        comisionEvaluareConverit
                    ),
                });

                values.push(
                    parseFloat(
                        (-(
                            balance -
                            comisionAnalizaRon -
                            parseFloat(localStorageObject.intregistrare_ron) -
                            asigurareCasa -
                            comisionEvaluareConverit
                        )).toFixed(2)
                    )
                );
            }
            //new line
            inregistrare = parseFloat(localStorageObject.intregistrare_ron);
            comisionAnaliza = comisionAnalizaRon;
        } else {
            if (tipCredit === "GPL") {
                values.push(
                    parseFloat(
                        (-(
                            balance -
                            comisionAnalizaEuro -
                            parseFloat(localStorageObject.intregistrare_euro)
                        )).toFixed(2)
                    )
                );
            } else {
                values.push(
                    parseFloat(
                        (-(
                            balance -
                            comisionAnalizaEuro -
                            parseFloat(localStorageObject.intregistrare_euro) -
                            asigurareCasa -
                            comisionEvaluareConverit
                        )).toFixed(2)
                    )
                );
            }
            //new line
            inregistrare = parseFloat(localStorageObject.intregistrare_euro);
            comisionAnaliza = comisionAnalizaEuro;
        }

        var vtp = 0;
        for (var count = 0; count < terms; ++count) {
            if (is3YFixed && count == 36) {
                monthlyRate = parseFloat((indice + marja) / 100.0) / 12.0;
                newTerms = terms - 36;
                payment =
                    balance * (monthlyRate / (1 - Math.pow(1 + monthlyRate, -newTerms)));
            }
            if (is5YFixed && count == 60) {
                monthlyRate = parseFloat((indice + marja) / 100.0) / 12.0;

                newTerms = terms - 60;
                payment =
                    balance * (monthlyRate / (1 - Math.pow(1 + monthlyRate, -newTerms)));
            }
            var soldDate = new Date();

            soldDate.setMonth(soldDate.getMonth() + count);
            var year = soldDate.getFullYear();
            var month = ("0" + (soldDate.getMonth() + 1)).slice(-2);
            var day = ("0" + soldDate.getDate()).slice(-2);

            var interest = 0;
            interest = balance * monthlyRate;

            var totalPay = 0;
            if (tipRambursareOption === "descrescatoare") {
                // var totalPay = payment + comisionLunar + interest
                totalPay = payment + comisionLunarCurrency + interest;
            } else {
                // var totalPay = payment + comisionLunar
                totalPay = payment + comisionLunarCurrency;
            }

            var monthlyPrincipal = 0;
            if (tipRambursareOption === "descrescatoare") {
                monthlyPrincipal = payment;
            }
            if (tipRambursareOption === "egale") {
                monthlyPrincipal = payment - interest;
            }

            result += "<tr align=center>";

            result += "<td>" + (count + 1) + "</td>";

            result += "<td>" + soldDate.toLocaleDateString("en-GB") + "</td>";
            if (count == 0) {
                firstMonthRate = totalPay;
            }
            dates.push(moment(`${year}/${month}/${day}`, "YYYY/MM/DD"));

            result += "<td> " + formatNumberValue(monthlyPrincipal, false) + "</td>";

            result += "<td> " + formatNumberValue(interest, false) + "</td>";

            //   result += '<td> ' + comisionLunar + '</td>'
            result += "<td> " + comisionLunarCurrency + "</td>";

            if (count === terms - 1) {
                var soldDateLast = new Date(soldDate);
                soldDateLast.setMonth(soldDateLast.getMonth() + 1);
                var y = soldDateLast.getFullYear();
                var m = ("0" + (soldDateLast.getMonth() + 1)).slice(-2);
                var d = ("0" + soldDateLast.getDate()).slice(-2);
                dates.push(moment(`${y}/${m}/${d}`, "YYYY/MM/DD"));

                if (currency === "RON") {
                    values.push(parseFloat((totalPay + stergereRon).toFixed(2)));
                    //new line
                    stergere = stergereRon;
                } else {
                    values.push(parseFloat((totalPay + stergereEuro).toFixed(2)));
                    //new line
                    stergere = stergereEuro;
                }
            }

            result +=
                "<td class='sumPerMonth'> " +
                formatNumberValue(totalPay, false) +
                "</td>";
            if (tipCredit === "GPLPlus" || tipCredit === "HL") {
                if ((count + 1) % 12 == 0 && count !== terms - 1) {
                    if (
                        (count + 1) % 60 == 0 &&
                        count !== terms - 1 &&
                        tipCredit === "HL"
                    ) {
                        values.push(
                            parseFloat(
                                (totalPay + asigurareCasa + reinnoireConvertit).toFixed(2)
                            )
                        );
                    } else {
                        values.push(parseFloat((totalPay + asigurareCasa).toFixed(2)));
                    }
                } else {
                    values.push(parseFloat(totalPay.toFixed(2)));
                }
            } else {
                values.push(parseFloat(totalPay.toFixed(2)));
            }

            if (count === terms - 1) {
                values.pop();
            }
            balance = balance - monthlyPrincipal;

            result += "<td> " + formatNumberValue(balance, false) + "</td>";

            result += "</tr>";

            vtp += totalPay;
        }
        //new line
        if (tipCredit === "GPL") {
            vtp = vtp + inregistrare + stergere + comisionAnaliza;
        }
        if (tipCredit === "GPLPlus") {
            const costEvaluare =
                currency === "RON"
                    ? comisionEvaluare
                    : comisionEvaluareConverit / cursEuro;
            const primaAsigurareImobilTotal =
                currency === "RON"
                    ? (parseInt(durataCredit / 12) + 1) *
                    (componentaPrimaImobil +
                        ((valoareCredit / 0.75) * componenta_prima_imobil_procent) / 100)
                    : (parseInt(durataCredit / 12) + 1) *
                    (componentaPrimaImobil / cursEuro +
                        ((valoareCredit / 0.75) * componenta_prima_imobil_procent) / 100);
            const rnpmCostTotal =
                inregistrare +
                stergere +
                (durataCredit == 60 ? reinnoireConvertit : 0) +
                (currency === "EUR"
                    ? 22 + (durataCredit < 60 ? reinnoireConvertit : 0)
                    : 0);
            const costuriOperationale =
                currency === "RON" ? 0 + 20 + 10 * cursEuro : 35 + 20 / cursEuro + 10;
            const comisionAdministrareCont = currency === "RON" ? 0 : 0 / cursEuro;

            vtp =
                vtp +
                comisionAnaliza +
                costEvaluare +
                primaAsigurareImobilTotal +
                rnpmCostTotal +
                costuriOperationale +
                comisionAdministrareCont;
            console.log("?????????????????????? GPLPlus post-processing:", {
                costEvaluare: costEvaluare,
                primaAsigurareImobilTotal: primaAsigurareImobilTotal,
                rnpmCostTotal: rnpmCostTotal,
                costuriOperationale: costuriOperationale,
                vtp: vtp,
            });
            if (values.length > 0) {
                values[0] = values[0] + costuriOperationale;
                if (durataCredit % 12 == 0) {
                    values[values.length - 1] =
                        values[values.length - 1] +
                        primaAsigurareImobilTotal / (parseInt(durataCredit / 12) + 1) -
                        stergere;
                } else {
                    values[values.length - 1] = values[values.length - 1] - stergere;
                }
                if (durataCredit == 60 && currency == "RON") {
                    values[values.length - 1] =
                        values[values.length - 1] + reinnoireConvertit;
                }
                if (currency === "EUR") {
                    values.push(reinnoireConvertit);
                    if (dates.length > 0) {
                        let firstDate = dates[0];
                        dates.push(
                            moment(
                                `${firstDate.year() + 30
                                }/${firstDate.month()}/${firstDate.date()}`,
                                "YYYY/MM/DD"
                            )
                        );
                    }
                }
            }
        }
        console.log("?????????????????????? values:", values);
        console.log("?????????????????????? dates:", dates);

        if (tipCredit === "HL") {
            const costEvaluare =
                currency === "RON"
                    ? comisionEvaluare
                    : comisionEvaluareConverit / cursEuro;
            const primaAsigurareImobilTotal =
                currency === "RON"
                    ? (parseInt(durataCredit / 12) + 1) *
                    (componentaPrimaImobil +
                        ((valoareCredit / 0.75) * componenta_prima_imobil_procent) / 100)
                    : (parseInt(durataCredit / 12) + 1) *
                    (componentaPrimaImobil / cursEuro +
                        ((valoareCredit / 0.65) * componenta_prima_imobil_procent) / 100);
            const rnpmCostTotal =
                inregistrare +
                stergere +
                (currency === "EUR" ? (durataCredit == 360 ? 0 : 22) : 0) +
                (currency == "RON"
                    ? parseInt(durataCredit / 60) * reinnoireConvertit
                    : Math.ceil(durataCredit / 60) * reinnoireConvertit);
            const costuriOperationale =
                currency === "RON" ? 0 + 20 + 10 * cursEuro : 35 + 20 / cursEuro + 10;
            const comisionAdministrareCont = currency === "RON" ? 0 : 0 / cursEuro;

            vtp =
                vtp +
                comisionAnaliza +
                costEvaluare +
                primaAsigurareImobilTotal +
                rnpmCostTotal +
                costuriOperationale +
                comisionAdministrareCont;
            if (values.length > 0) {
                values[0] = values[0] + costuriOperationale;
                if (durataCredit % 12 == 0) {
                    values[values.length - 1] =
                        values[values.length - 1] +
                        primaAsigurareImobilTotal / (parseInt(durataCredit / 12) + 1) -
                        stergere;
                }
                if (durataCredit == 60 && currency == "RON") {
                    values[values.length - 1] =
                        values[values.length - 1] + reinnoireConvertit;
                }
                if (currency === "EUR") {
                    if (dates.length > 0) {
                        let firstDate = dates[0];
                        if (dates.length < 360 + 1) {
                            values.push(reinnoireConvertit);
                            dates.push(
                                moment(
                                    `${firstDate.year() + 30
                                    }/${firstDate.month()}/${firstDate.date()}`,
                                    "YYYY/MM/DD"
                                )
                            );
                        }
                    }
                }
            }
        }

        // Debug log for values array before XIRR calculation
        console.log("DEBUG - Before XIRR calculation:", {
            valuesLength: values.length,
            datesLength: dates.length,
            firstFewValues: values.slice(0, 3),
            lastFewValues: values.slice(-3),
            vtp: vtp,
        });

        // Debug log for validating positive and negative values in the array
        let hasPositive = values.some((v) => v > 0);
        let hasNegative = values.some((v) => v < 0);
        console.log("DEBUG - Values validation:", {
            hasPositive: hasPositive,
            hasNegative: hasNegative,
            requiresBoth:
                "The XIRR function requires both positive and negative values",
        });

        DAE = XIRR(values, dates) * 100;
        console.log("DEBUG - After XIRR calculation:", {
            DAE: DAE,
            vtp: vtp,
        });

        result += "</table>";
        document.querySelector(".perioada > span").textContent = `${terms} luni`;
        document.querySelector(".dae > span").textContent = `${formatNumberValue(
            DAE
        )}%`;
        document.querySelector(
            ".valoarea-totala-de-plata > span"
        ).textContent = `${formatNumberValue(vtp)} ${currency === "RON" ? "RON" : "EUR"
        }`;
        // document.querySelector('.comision-lunar > span').textContent = `${comisionLunar} ${tipCredit === 'GPL' ? `${currency === 'RON' ? 'RON' : 'EUR'}` : `%`}`
        document.querySelector(
            ".comision-lunar > span"
        ).textContent = `${comisionLunarCurrency} ${currency === "RON" ? "RON" : "EUR"
        }`;
        document.querySelector(
            ".rata-dobanzii > span"
        ).textContent = `${formatNumberValue(dobandaFixa)}%/an`;
        // document.querySelector('.valoarea-ratei > span').textContent = `${parseFloat(firstMonthRate)
        //     .toFixed(2) //alex
        //     .replace(".", ',')
        //     .replace(/\B(?=(\d{3})+(?!\d))/g, '.')} ${currency === 'RON' ? 'RON' : 'EUR'}` //old
        document.querySelector(
            ".valoarea-ratei > span"
        ).textContent = `${formatNumberValue(firstMonthRate)} ${currency === "RON" ? "RON" : "EUR"
        }`;
        document.querySelector(
            ".comision-analiza > span"
        ).textContent = `${comisionAnalizaToDisplay} ${currency === "RON" ? "RON" : "EUR"
        }`;
        document.querySelector(
            ".comision-evaluare > span"
        ).textContent = `${formatNumberValue(comisionEvaluare)} RON`;
        return result;
    }

    function validateInputs(value) {
        if (value == null || value == "") {
            return false;
        } else {
            return true;
        }
    }

    function exportToExcel(type, fn, dl) {
        var elt = document.getElementById("tbl_exporttable_to_xls");
        var wb = XLSX.utils.table_to_book(elt, { sheet: "sheet1" });
        return dl
            ? XLSX.write(wb, { bookType: type, bookSST: true, type: "base64" })
            : XLSX.writeFile(wb, fn || "Costuri si taxe credit." + (type || "xlsx"));
    }

    var specialElementHandlers = {
        ".no-export": function (element, renderer) {
            return true;
        },
    };

    function exportWithoutSepcialCharacters(id) {
        document.querySelector(
            "#tbl_exporttable_to_xls > tbody > tr:nth-child(1) > th:nth-child(1)"
        ).textContent = "Luna";
        document.querySelector(
            "#tbl_exporttable_to_xls > tbody > tr:nth-child(1) > th:nth-child(2)"
        ).textContent = "Data";
        document.querySelector(
            "#tbl_exporttable_to_xls > tbody > tr:nth-child(1) > th:nth-child(4)"
        ).textContent = "Dobanda";
        document.querySelector(
            "#tbl_exporttable_to_xls > tbody > tr:nth-child(1) > th:nth-child(5)"
        ).textContent = "Comision Lunar";
        document.querySelector(
            "#tbl_exporttable_to_xls > tbody > tr:nth-child(1) > th:nth-child(6)"
        ).textContent = "Total Plata Lunara";

        function exportPDF(id) {
            var doc = new jsPDF("p", "pt", "a2");

            var source = document.getElementById(id);
            var margins = {
                top: 10,
                bottom: 10,
                left: 10,
                width: 595,
            };

            doc.fromHTML(
                source,
                margins.left,
                margins.top,
                {
                    width: margins.width,
                    elementHandlers: specialElementHandlers,
                },

                function (dispose) {
                    doc.save("Costuri si taxe credit.pdf");
                },
                margins
            );
        }
        exportPDF(id);
        document.querySelector(
            "#tbl_exporttable_to_xls > tbody > tr:nth-child(1) > th:nth-child(1)"
        ).textContent = "Lună";
        document.querySelector(
            "#tbl_exporttable_to_xls > tbody > tr:nth-child(1) > th:nth-child(2)"
        ).textContent = "Dată";
        document.querySelector(
            "#tbl_exporttable_to_xls > tbody > tr:nth-child(1) > th:nth-child(4)"
        ).textContent = "Dobândă";
        document.querySelector(
            "#tbl_exporttable_to_xls > tbody > tr:nth-child(1) > th:nth-child(5)"
        ).innerHTML = "Comision </br> Lunar";
        document.querySelector(
            "#tbl_exporttable_to_xls > tbody > tr:nth-child(1) > th:nth-child(6)"
        ).innerHTML = "Total Plata </br> Lunară";
    }
    function runScript() {
        if (localStorageObject) {
            // Debug log for important values from localStorage
            console.log("DEBUG - localStorage values:", {
                balance: balance,
                duration: terms,
                interestRate: dobandaFixa,
                tipCredit: tipCredit,
                currency: currency,
                hasSalary: hasSalary,
                is3YFixed: is3YFixed,
                is5YFixed: is5YFixed,
                tipRambursareOption: localStorage.getItem("tipRambursareOption"),
            });
            getValues();
        } else {
            console.error("DEBUG - localStorageObject is missing");
            return;
        }
    }
    window.addEventListener("load", runScript());
</script>				</div>
